{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(vnx *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"{{ engine_root }}/scripts/hooks/stop_report_hook.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"{{ engine_root }}/scripts/hooks/pretooluse_block_raw_claude_spawn.sh\"'",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
