{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null) && exec bash \"$ROOT/.claude/hooks/post_tool_use_format.sh\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null) && python3 \"$ROOT/scripts/build_current_state.py\" 2>/dev/null && python3 \"$ROOT/scripts/build_doc_indexes.py\" 2>/dev/null; exit 0'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "terminals/T0",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/build_t0_state.py --output .vnx-data/state/t0_state.json 2>/dev/null; exit 0"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null) && exec bash \"$ROOT/.claude/hooks/session_start_context.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/hooks/stop_report_hook.sh\"'"
          }
        ]
      }
    ]
  }
}
