  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$PWD\" == */T1 ]] || [[ \"$PWD\" == */T2 ]] || [[ \"$PWD\" == */T3 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/vnx_rotation_recovery.sh --fallback /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/sessionstart.sh; else bash /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/sessionstart.sh; fi",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$PWD\" == */T0 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/scripts/userpromptsubmit_intelligence_inject_v5.sh; elif [[ \"$PWD\" == */T1 ]] || [[ \"$PWD\" == */T2 ]] || [[ \"$PWD\" == */T3 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/scripts/userpromptsubmit_worker_intelligence_inject.sh; else echo '{\"decision\": \"allow\"}'; fi",
            "timeout": 8000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/t0-readonly-enforcer.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$PWD\" == */T1 ]] || [[ \"$PWD\" == */T2 ]] || [[ \"$PWD\" == */T3 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/hooks/vnx_context_monitor.sh; else echo '{\"decision\":\"allow\"}'; fi",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/activate_venv.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/hooks/vnx_handover_detector.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/hooks/vnx_context_monitor.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "_vnx_meta": {
    "version": "2.0",
    "managed_keys": [
      "hooks",
      "env.VNX_*",
      "permissions.allow(vnx_baseline)",
      "permissions.deny(vnx_baseline)"
    ],
    "description": "VNX-owned settings keys. Merged by 'vnx regen-settings --merge'."
  }
}
