{
  "env": {
    "PYTHONPATH": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/src",
    "SEOCRAWLER_VENV": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv",
    "VIRTUAL_ENV": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv",
    "PATH": "/Users/vincentvandeth/.nvm/versions/node/v20.18.2/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv/bin:/Users/vincentvandeth/.local/bin",
    "VNX_CONTEXT_ROTATION_ENABLED": "1"
  },
  "permissions": {
    "additionalDirectories": [
      "terminals/T0",
      "terminals/T1",
      "terminals/T2", 
      "terminals/T3",
      "vnx-system",
      "./"
    ],
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash"
    ],
    "ask": [
      "Write(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "NotebookEdit(**)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$PWD\" == */T0 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/sessionstart_t0_minimal.sh; elif [[ \"$PWD\" == */T1 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/vnx_rotation_recovery.sh; elif [[ \"$PWD\" == */T2 ]] || [[ \"$PWD\" == */T3 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/vnx_rotation_recovery.sh --fallback /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/sessionstart_worker.sh; elif [[ \"$PWD\" == */T-MANAGER ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/sessionstart_tmanager_minimal.sh; else echo '{}' ; fi",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$PWD\" == */T0 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/scripts/userpromptsubmit_intelligence_inject_v5.sh; elif [[ \"$PWD\" == */T1 ]] || [[ \"$PWD\" == */T2 ]] || [[ \"$PWD\" == */T3 ]]; then /Users/vincentvandeth/Development/vnx-system-wt-upgrade/scripts/userpromptsubmit_worker_intelligence_inject.sh; else echo '{\"decision\": \"allow\"}'; fi",
            "timeout": 8000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/t0-readonly-enforcer.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/hooks/activate_venv.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "NEVER_MATCH_THIS_PATTERN_DISABLED",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/posttool_to_t0.sh"
          }
        ]
      },
      {
        "matcher": "DISABLED_FOR_MANUAL_INIT",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/venv_python.sh $CLAUDE_PROJECT_DIR/.claude/hooks/worker_prompt_summary.py",
            "timeout": 1000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/vnx-system/hooks/vnx_handover_detector.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.claude/vnx-system/hooks/vnx_context_monitor.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
