{
  "env": {
    "PYTHONPATH": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/src",
    "SEOCRAWLER_VENV": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv",
    "VIRTUAL_ENV": "/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv",
    "PATH": "/Users/vincentvandeth/.nvm/versions/node/v20.18.2/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/vincentvandeth/Development/vnx-system-wt-upgrade/.venv/bin:/Users/vincentvandeth/.local/bin",
    "VNX_CONTEXT_ROTATION_ENABLED": "1"
