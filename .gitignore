# VNX runtime artifacts (local only) — strategic docs moved to claudedocs/ (OI-1373 Tiers 1-5)
.vnx-data/*
.vnx-data/state/*
state/
state_archive_*/
state_archive/
t0_receipts.ndjson
logs/
pids/
locks/
dispatches/
!demo/dry-run/evidence/dispatches/
unified_reports/
receipts/
queue/
reports/
!demo/dry-run/evidence/reports/
!dashboard/token-dashboard/app/operator/reports/
orchestration/

# Database runtime files (generated locally by init scripts)
database/*.db
ledger/storage/*.db

# Benchmark field-tests: generated seed DBs (rebuilt per run)
scripts/benchmark/field-tests/tasks/**/seed/*.db
scripts/benchmark/field-tests/tasks/**/seed/*.db.stale

# Archive and backup directories (not part of current system)
archive/
backup_*/
docs/archive/

# Internal docs (not for public repo — all internal docs go in docs/internal/)
docs/internal/
docs/roadmap/
docs/architecture/

# Old versioned scripts (superseded)
scripts/claude_auth_check.sh
scripts/userpromptsubmit_intelligence_inject.sh

# Scripts runtime state
scripts/state/
scripts/.pr_state.json
scripts/PR_QUEUE.md

# Temp/one-off scripts
fix_git_history.sh

# Root-level runtime files
index.html
!dashboard/index.html

# Runtime PID files
*.pid

# Claude Code runtime lock files
.claude/scheduled_tasks.lock

# Claude Code local overrides (per-maintainer, never published)
CLAUDE.local.md
.claude/settings.local.json

# Local runtime logs
scripts/*.log
scripts/smart_tap.log

# Python runtime artifacts
__pycache__/
*.pyc

# Python packaging build artifacts (never commit)
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/

# Scratch/advisory docs (generated, not part of source)
CHANGELOG_QUALITY_ADVISORY.md

# PR queue runtime artifacts (do not commit)
/.pr_state.json
/PR_QUEUE.md

# Old config directory (merged into configs/) — root-anchored so it does not match
# nested app routes like dashboard/token-dashboard/app/operator/config/
/config/

# Old testing directory (merged into tests/)
testing/

# Private per-project prep migrations — never publish
schemas/prep_migrations/

# Environment files
.env
.env.*
# ...but benchmark task seed .env fixtures ARE tracked (dummy placeholders only) so a
# clean worktree checkout materializes them. Without this the seed .env is absent in the
# worker worktree → verify.py crashes (infra-fail, not a model capability fail).
!scripts/benchmark/field-tests/tasks/**/seed/.env

# VNX provider secrets
vnx.env
.vnx/vnx.env

# macOS
.DS_Store

# Test result artifacts
tests/*.log
tests/*_RESULTS.md
tests/*_ISSUE.md

# Project-specific integration tests (not part of generic VNX)
tests/test_carina_*.py
claudedocs/
.vnx-intelligence/
*.tsbuildinfo

# t6 real-codebase-review tier — INTERNAL ONLY (reviews proprietary repos; never publish)
scripts/benchmark/field-tests/tasks/t6_real_review/
scripts/benchmark/field-tests/tasks.local.yaml
