#!/usr/bin/env bash
# VNX Bootstrap CLI (Phase P2)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export VNX_BIN="$SCRIPT_DIR/$(basename "${BASH_SOURCE[0]}")"
export VNX_EXECUTABLE="$VNX_BIN"

# CRITICAL: Always compute PROJECT_ROOT from script location.
# Never inherit from environment — prevents cross-project contamination
# (e.g. SEOcrawler PROJECT_ROOT leaking into marketing-magic-circle).
# Preserve VNX_DATA_DIR if explicitly set (worktree isolation)
_VNX_SAVED_DATA_DIR="${VNX_DATA_DIR:-}"
unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR
[ -n "$_VNX_SAVED_DATA_DIR" ] && export VNX_DATA_DIR="$_VNX_SAVED_DATA_DIR"
unset _VNX_SAVED_DATA_DIR

if [ -f "$SCRIPT_DIR/../scripts/lib/vnx_paths.sh" ]; then
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/../scripts/lib/vnx_paths.sh"
else
  VNX_HOME_DEFAULT="$(cd "$SCRIPT_DIR/.." && pwd)"
  if [ "$(basename "$VNX_HOME_DEFAULT")" = "vnx-system" ] && [ "$(basename "$(dirname "$VNX_HOME_DEFAULT")")" = ".claude" ]; then
    PROJECT_ROOT_DEFAULT="$(cd "$VNX_HOME_DEFAULT/../.." && pwd)"
  else
    PROJECT_ROOT_DEFAULT="$(cd "$VNX_HOME_DEFAULT/.." && pwd)"
  fi

  export VNX_HOME="${VNX_HOME:-$VNX_HOME_DEFAULT}"
  export PROJECT_ROOT="${PROJECT_ROOT:-$PROJECT_ROOT_DEFAULT}"
  export VNX_DATA_DIR="${VNX_DATA_DIR:-$PROJECT_ROOT/.vnx-data}"
  export VNX_STATE_DIR="${VNX_STATE_DIR:-$VNX_DATA_DIR/state}"
  export VNX_DISPATCH_DIR="${VNX_DISPATCH_DIR:-$VNX_DATA_DIR/dispatches}"
  export VNX_LOGS_DIR="${VNX_LOGS_DIR:-$VNX_DATA_DIR/logs}"
  export VNX_PIDS_DIR="${VNX_PIDS_DIR:-$VNX_DATA_DIR/pids}"
  export VNX_LOCKS_DIR="${VNX_LOCKS_DIR:-$VNX_DATA_DIR/locks}"
  export VNX_REPORTS_DIR="${VNX_REPORTS_DIR:-$VNX_DATA_DIR/unified_reports}"
  export VNX_DB_DIR="${VNX_DB_DIR:-$VNX_DATA_DIR/database}"

  if [ -d "$PROJECT_ROOT_DEFAULT/.claude/skills" ]; then
    export VNX_SKILLS_DIR="$PROJECT_ROOT_DEFAULT/.claude/skills"
  else
    export VNX_SKILLS_DIR="${VNX_SKILLS_DIR:-$VNX_HOME_DEFAULT/skills}"
  fi
fi

# Worktree env override: if CWD has .vnx-data/.env_override, source it
_vnx_cwd_override="$(pwd)/.vnx-data/.env_override"
if [ -f "$_vnx_cwd_override" ]; then
  # shellcheck source=/dev/null
  source "$_vnx_cwd_override"
fi
unset _vnx_cwd_override

if [ -f "$SCRIPT_DIR/../scripts/lib/vnx_marked_blocks.sh" ]; then
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/../scripts/lib/vnx_marked_blocks.sh"
fi

VNX_CONFIG_DIR="${PROJECT_ROOT}/.vnx"
VNX_CONFIG_FILE="${VNX_CONFIG_DIR}/config.yml"
TERMINALS_TEMPLATE_DIR="${VNX_HOME}/templates/terminals"
SNIPPETS_TEMPLATE_DIR="${VNX_HOME}/templates/snippets"

MARKER_BEGIN="<!-- VNX:BEGIN BOOTSTRAP -->"
MARKER_END="<!-- VNX:END BOOTSTRAP -->"

log() {
  printf '%s\n' "$*"
}

err() {
  printf 'ERROR: %s\n' "$*" >&2
}

  usage() {
    cat <<USAGE
Usage: vnx <command>

Commands:
  init               Create .vnx-data runtime layout and .vnx/config.yml
  init-db            Initialize quality intelligence database from schema
  bootstrap-skills   Create/link ./\.claude/skills from shipped dist skills
  bootstrap-terminals  Create ./\.claude/terminals (default: T0..T3)
  bootstrap-hooks    Deploy SessionStart hooks to .claude/hooks/ + settings.json
  start [--profile X] Launch VNX tmux session (interactive profile selection)
                     Profiles: claude-only, claude-codex, claude-gemini, full-multi
  start --preset <name>  Start with a saved startup preset
  start --last           Start with last-used startup configuration
  stop               Stop VNX tmux session and orchestration processes
  doctor             Validate layout, dependencies, and path hygiene
  smoke              Run one-shot local receipt pipeline smoke test
  cost-report        Aggregate model usage + estimated cost from receipts
  package-check      Fail if runtime artifacts exist inside dist
  update [url] [branch]  Pull latest VNX from origin and re-install
  update --pin <tag>     Pin VNX version (respects lock on future updates)
  update --check         Dry-run: show current vs available version
  update --latest        Update ignoring version.lock
  patch-agent-files  Insert/update VNX marked block in CLAUDE.md / AGENTS.md
  suggest <sub>      Human-in-the-loop system tuning (review/accept/reject/apply/history)

Intelligence commands (git-tracked project knowledge):
  intelligence-export  Export SQLite + state to .vnx-intelligence/ (NDJSON)
  intelligence-import  Import .vnx-intelligence/ NDJSON into SQLite

Worktree commands (data isolation):
  worktree-start     Initialize isolated .vnx-data with intelligence snapshot
  worktree-stop      Merge intelligence back to main and clean up
  worktree-refresh   Update intelligence snapshot from main
  worktree-status    Show worktree isolation status

  help               Show this help text
USAGE
  }

ensure_runtime_layout() {
  mkdir -p "$VNX_DATA_DIR" \
    "$VNX_STATE_DIR" \
    "$VNX_LOGS_DIR" \
    "$VNX_PIDS_DIR" \
    "$VNX_LOCKS_DIR" \
    "$VNX_DISPATCH_DIR/pending" \
    "$VNX_DISPATCH_DIR/active" \
    "$VNX_DISPATCH_DIR/completed" \
    "$VNX_DISPATCH_DIR/rejected" \
    "$VNX_DISPATCH_DIR/failed" \
    "$VNX_REPORTS_DIR" \
    "$VNX_DB_DIR" \
    "$VNX_DATA_DIR/receipts" \
    "$VNX_DATA_DIR/profiles" \
    "$VNX_DATA_DIR/startup_presets"

  # Write provider profiles if they don't exist yet (idempotent).
  _write_profiles_if_missing "$VNX_DATA_DIR/profiles"

  # Write default startup presets if they don't exist yet (idempotent).
  _write_default_presets_if_missing "$VNX_DATA_DIR/startup_presets"
}

_write_profiles_if_missing() {
  local dir="$1"

  # claude-only: all terminals run Claude Code
  if [ ! -f "$dir/claude-only.env" ]; then
    cat > "$dir/claude-only.env" <<'ENV'
# VNX Profile: claude-only
# All worker terminals use Claude Code (claude).
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # claude-codex: T1 uses Codex CLI, T2 uses Claude Code
  if [ ! -f "$dir/claude-codex.env" ]; then
    cat > "$dir/claude-codex.env" <<'ENV'
# VNX Profile: claude-codex
# T1 uses Codex CLI, T2 uses Claude Code.
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # claude-gemini: T1 uses Gemini CLI, T2 uses Claude Code
  if [ ! -f "$dir/claude-gemini.env" ]; then
    cat > "$dir/claude-gemini.env" <<'ENV'
# VNX Profile: claude-gemini
# T1 uses Gemini CLI, T2 uses Claude Code.
VNX_T1_PROVIDER=gemini_cli
VNX_T2_PROVIDER=claude_code
ENV
  fi

  # full-multi: T1 uses Codex CLI, T2 uses Gemini CLI
  if [ ! -f "$dir/full-multi.env" ]; then
    cat > "$dir/full-multi.env" <<'ENV'
# VNX Profile: full-multi
# T1 uses Codex CLI, T2 uses Gemini CLI.
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=gemini_cli
ENV
  fi
}

_write_default_presets_if_missing() {
  local dir="$1"

  if [ ! -f "$dir/full-auto.env" ]; then
    cat > "$dir/full-auto.env" <<'ENV'
# Preset: full-auto
# All Claude, skip-permissions on all workers
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=1
VNX_T2_SKIP_PERMISSIONS=1
VNX_T3_SKIP_PERMISSIONS=1
VNX_QUEUE_POPUP_ENABLED=1
ENV
  fi

  if [ ! -f "$dir/review-mode.env" ]; then
    cat > "$dir/review-mode.env" <<'ENV'
# Preset: review-mode
# All Claude, no skip-permissions (manual approval)
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=claude_code
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=0
VNX_T2_SKIP_PERMISSIONS=0
VNX_T3_SKIP_PERMISSIONS=0
VNX_QUEUE_POPUP_ENABLED=1
ENV
  fi

  if [ ! -f "$dir/claude-codex-auto.env" ]; then
    cat > "$dir/claude-codex-auto.env" <<'ENV'
# Preset: claude-codex-auto
# T1=Codex, T2=Claude, skip-permissions on T1
VNX_T0_PROVIDER=claude_code
VNX_T1_PROVIDER=codex_cli
VNX_T2_PROVIDER=claude_code
VNX_T3_PROVIDER=claude_code
VNX_T0_SKIP_PERMISSIONS=0
VNX_T1_SKIP_PERMISSIONS=1
VNX_T2_SKIP_PERMISSIONS=1
VNX_T3_SKIP_PERMISSIONS=0
VNX_QUEUE_POPUP_ENABLED=1
ENV
  fi
}

# ── Interactive Startup Menu ─────────────────────────────────────────────────
# Presents saved presets and custom per-terminal configuration.
# Sets VNX_T{0..3}_PROVIDER, VNX_T{0..3}_SKIP_PERMISSIONS, VNX_QUEUE_POPUP_ENABLED.
# Returns 0 on success, 1 on abort.
_interactive_startup_menu() {
  local presets_dir="$1"
  mkdir -p "$presets_dir"

  # Collect available presets
  local -a preset_files preset_names preset_descs
  local i=0

  # Always show last-used first if it exists
  local last_used_target=""
  if [ -L "$presets_dir/last-used.env" ] && [ -f "$presets_dir/last-used.env" ]; then
    last_used_target="$(readlink "$presets_dir/last-used.env" 2>/dev/null || true)"
    last_used_target="$(basename "${last_used_target%.env}")"
  fi

  for f in "$presets_dir/"*.env; do
    [ -f "$f" ] || continue
    local bname
    bname="$(basename "${f%.env}")"
    [ "$bname" = "last-used" ] && continue
    preset_files+=("$f")
    preset_names+=("$bname")
    local desc
    desc="$(grep '^# Preset:' "$f" 2>/dev/null | head -1 | sed 's/^# Preset: //')"
    local detail
    detail="$(sed -n '3p' "$f" 2>/dev/null | sed 's/^# //')"
    preset_descs+=("${detail:-$desc}")
    i=$((i + 1))
  done

  echo ""
  echo "  ╔═══════════════════════════════════════════════════╗"
  echo "  ║              VNX Startup Configuration            ║"
  echo "  ╠═══════════════════════════════════════════════════╣"
  echo "  ║                                                   ║"
  echo "  ║  Saved presets:                                   ║"

  local j=1
  for idx in "${!preset_names[@]}"; do
    local marker=""
    [ "${preset_names[$idx]}" = "$last_used_target" ] && marker=" (last)"
    printf "  ║    %d) %-15s %-28s║\n" "$j" "${preset_names[$idx]}${marker}" "${preset_descs[$idx]:0:28}"
    j=$((j + 1))
  done

  echo "  ║    c) Custom configuration...                     ║"
  echo "  ║                                                   ║"
  echo "  ╠═══════════════════════════════════════════════════╣"
  if [ -n "$last_used_target" ]; then
    echo "  ║  Quick start: press Enter for '$last_used_target'     ║"
  else
    echo "  ║  Quick start: press Enter for first preset        ║"
  fi
  echo "  ╚═══════════════════════════════════════════════════╝"
  echo ""
  printf "  Select [1-%d/c]: " "${#preset_names[@]}"
  local choice
  read -r choice

  # Default: load last-used or first preset
  if [ -z "$choice" ]; then
    if [ -n "$last_used_target" ] && [ -f "$presets_dir/last-used.env" ]; then
      source "$presets_dir/last-used.env"
      log "Loaded preset: last-used ($last_used_target)"
      return 0
    elif [ "${#preset_files[@]}" -gt 0 ]; then
      source "${preset_files[0]}"
      _update_last_used "$presets_dir" "${preset_files[0]}"
      log "Loaded preset: ${preset_names[0]}"
      return 0
    fi
  fi

  # Custom configuration
  if [ "$choice" = "c" ] || [ "$choice" = "C" ]; then
    _custom_terminal_config "$presets_dir"
    return $?
  fi

  # Numeric preset selection
  if [ -n "$choice" ] && [ "$choice" -ge 1 ] 2>/dev/null && [ "$choice" -le "${#preset_names[@]}" ] 2>/dev/null; then
    local sel_idx=$((choice - 1))
    source "${preset_files[$sel_idx]}"
    _update_last_used "$presets_dir" "${preset_files[$sel_idx]}"
    log "Loaded preset: ${preset_names[$sel_idx]}"
    return 0
  fi

  echo "  Invalid choice."
  return 1
}

_custom_terminal_config() {
  local presets_dir="$1"

  echo ""
  echo "  Terminal Configuration"
  echo "  ──────────────────────"
  echo "  T0 (Orchestrator):  Claude Opus    [fixed]"

  # T1 provider
  printf "  T1 (Track A):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t1_choice
  read -r t1_choice
  case "$t1_choice" in
    2) export VNX_T1_PROVIDER=codex_cli ;;
    3) export VNX_T1_PROVIDER=gemini_cli ;;
    *) export VNX_T1_PROVIDER=claude_code ;;
  esac

  # T2 provider
  printf "  T2 (Track B):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t2_choice
  read -r t2_choice
  case "$t2_choice" in
    2) export VNX_T2_PROVIDER=codex_cli ;;
    3) export VNX_T2_PROVIDER=gemini_cli ;;
    *) export VNX_T2_PROVIDER=claude_code ;;
  esac

  # T3 provider
  printf "  T3 (Track C):       [1] Claude  [2] Codex  [3] Gemini  → "
  local t3_choice
  read -r t3_choice
  case "$t3_choice" in
    2) export VNX_T3_PROVIDER=codex_cli ;;
    3) export VNX_T3_PROVIDER=gemini_cli ;;
    *) export VNX_T3_PROVIDER=claude_code ;;
  esac

  export VNX_T0_PROVIDER=claude_code

  echo ""
  echo "  Permission Mode"
  echo "  ───────────────"
  printf "  T0: Skip permissions?  [y/N] → "
  local sp0; read -r sp0
  [ "$sp0" = "y" ] || [ "$sp0" = "Y" ] && export VNX_T0_SKIP_PERMISSIONS=1 || export VNX_T0_SKIP_PERMISSIONS=0

  printf "  T1: Skip permissions?  [y/N] → "
  local sp1; read -r sp1
  [ "$sp1" = "y" ] || [ "$sp1" = "Y" ] && export VNX_T1_SKIP_PERMISSIONS=1 || export VNX_T1_SKIP_PERMISSIONS=0

  printf "  T2: Skip permissions?  [y/N] → "
  local sp2; read -r sp2
  [ "$sp2" = "y" ] || [ "$sp2" = "Y" ] && export VNX_T2_SKIP_PERMISSIONS=1 || export VNX_T2_SKIP_PERMISSIONS=0

  printf "  T3: Skip permissions?  [y/N] → "
  local sp3; read -r sp3
  [ "$sp3" = "y" ] || [ "$sp3" = "Y" ] && export VNX_T3_SKIP_PERMISSIONS=1 || export VNX_T3_SKIP_PERMISSIONS=0

  echo ""
  echo "  Queue Popup"
  echo "  ───────────"
  printf "  Enable queue popup watcher? [Y/n] → "
  local qp; read -r qp
  [ "$qp" = "n" ] || [ "$qp" = "N" ] && export VNX_QUEUE_POPUP_ENABLED=0 || export VNX_QUEUE_POPUP_ENABLED=1

  echo ""
  printf "  Save as preset? [name/N] → "
  local save_name
  read -r save_name

  if [ -n "$save_name" ] && [ "$save_name" != "N" ] && [ "$save_name" != "n" ]; then
    local preset_file="$presets_dir/${save_name}.env"
    cat > "$preset_file" <<ENV
# Preset: $save_name
# Custom configuration
VNX_T0_PROVIDER=${VNX_T0_PROVIDER}
VNX_T1_PROVIDER=${VNX_T1_PROVIDER}
VNX_T2_PROVIDER=${VNX_T2_PROVIDER}
VNX_T3_PROVIDER=${VNX_T3_PROVIDER}
VNX_T0_SKIP_PERMISSIONS=${VNX_T0_SKIP_PERMISSIONS}
VNX_T1_SKIP_PERMISSIONS=${VNX_T1_SKIP_PERMISSIONS}
VNX_T2_SKIP_PERMISSIONS=${VNX_T2_SKIP_PERMISSIONS}
VNX_T3_SKIP_PERMISSIONS=${VNX_T3_SKIP_PERMISSIONS}
VNX_QUEUE_POPUP_ENABLED=${VNX_QUEUE_POPUP_ENABLED}
ENV
    log "Preset saved: $preset_file"
    _update_last_used "$presets_dir" "$preset_file"
  else
    # Write a temporary last-used even without saving
    local tmp_file="$presets_dir/_last_custom.env"
    cat > "$tmp_file" <<ENV
# Preset: _last_custom
# Unsaved custom configuration
VNX_T0_PROVIDER=${VNX_T0_PROVIDER}
VNX_T1_PROVIDER=${VNX_T1_PROVIDER}
VNX_T2_PROVIDER=${VNX_T2_PROVIDER}
VNX_T3_PROVIDER=${VNX_T3_PROVIDER}
VNX_T0_SKIP_PERMISSIONS=${VNX_T0_SKIP_PERMISSIONS}
VNX_T1_SKIP_PERMISSIONS=${VNX_T1_SKIP_PERMISSIONS}
VNX_T2_SKIP_PERMISSIONS=${VNX_T2_SKIP_PERMISSIONS}
VNX_T3_SKIP_PERMISSIONS=${VNX_T3_SKIP_PERMISSIONS}
VNX_QUEUE_POPUP_ENABLED=${VNX_QUEUE_POPUP_ENABLED}
ENV
    _update_last_used "$presets_dir" "$tmp_file"
  fi

  return 0
}

_update_last_used() {
  local presets_dir="$1"
  local target_file="$2"
  rm -f "$presets_dir/last-used.env"
  ln -s "$target_file" "$presets_dir/last-used.env"
}

write_default_config_if_missing() {
  mkdir -p "$VNX_CONFIG_DIR"

  if [ -f "$VNX_CONFIG_FILE" ]; then
    log "[init] Keeping existing config: $VNX_CONFIG_FILE"
    return 0
  fi

  cat > "$VNX_CONFIG_FILE" <<CFG
# Generated by vnx init
project_root: "$PROJECT_ROOT"
vnx_home: "$VNX_HOME"
vnx_data_dir: "$VNX_DATA_DIR"
terminals_template_dir: "$TERMINALS_TEMPLATE_DIR"
CFG

  log "[init] Wrote config: $VNX_CONFIG_FILE"
}

cmd_intelligence_export() {
  python3 "$VNX_HOME/scripts/intelligence_export.py"
}

cmd_intelligence_import() {
  python3 "$VNX_HOME/scripts/intelligence_import.py"
}

cmd_init() {
  ensure_runtime_layout
  write_default_config_if_missing

  # Onboarding: ensure skills + terminals + hooks exist for a fresh project.
  cmd_bootstrap_skills || true
  cmd_bootstrap_terminals || true
  cmd_bootstrap_hooks || true

  # Multi-provider instruction files (AGENTS.md for Codex, GEMINI.md for Gemini).
  cmd_patch_agent_files || true

  # Initialize quality intelligence database (idempotent — uses IF NOT EXISTS).
  cmd_init_db || true

  # If git-tracked intelligence exists, hydrate SQLite from it.
  if [ -d "$VNX_INTELLIGENCE_DIR/db_export" ]; then
    log "[init] Found .vnx-intelligence/ — importing into SQLite..."
    cmd_intelligence_import || true
  fi

  log "[init] Runtime root ready: $VNX_DATA_DIR"
  log "[init] Done. Next: vnx doctor"
}

cmd_init_db() {
  local db_init_script="$VNX_HOME/scripts/quality_db_init.py"
  local schema_file="$VNX_HOME/schemas/quality_intelligence.sql"
  local db_path="$VNX_STATE_DIR/quality_intelligence.db"

  if [ ! -f "$schema_file" ]; then
    log "[init-db] WARN: Schema file not found: $schema_file (skipping)"
    return 0
  fi

  if [ ! -f "$db_init_script" ]; then
    # Fallback: apply schema directly via sqlite3 if init script missing
    if command -v sqlite3 >/dev/null 2>&1; then
      mkdir -p "$VNX_STATE_DIR"
      sqlite3 "$db_path" < "$schema_file"
      log "[init-db] Database initialized via sqlite3: $db_path"
    else
      log "[init-db] WARN: Neither quality_db_init.py nor sqlite3 available (skipping)"
    fi
    return 0
  fi

  # Use the full Python init script (handles backup, verification, metrics)
  python3 "$db_init_script"
  log "[init-db] Quality intelligence database ready"
}

print_terminal_command() {
  local terminal="$1"
  local template_file="$2"
  local index="$3"

  printf '%s) %s\n' "$index" "$terminal"
  printf '   cd %q && cat %q\n' "$PROJECT_ROOT" "$template_file"
}

# ── Comprehensive orchestration process cleanup ───────────────────────
# Kills ALL VNX orchestration processes for this project. Previous
# versions only killed smart_tap and dispatcher, causing duplicate
# receipt_processors, supervisors, and orphan fswatches that steal
# filesystem events from each other → receipts never delivered to T0.
vnx_kill_all_orchestration() {
  local scripts_dir="$1"
  local log_dir="$2"
  local reason="${3:-session_cleanup}"
  local lifecycle_log="$log_dir/process_lifecycle.log"
  local timeout=3

  # Source process control library for safe pid-checked kills
  if [ -f "$scripts_dir/lib/ops_process_control.sh" ]; then
    # shellcheck disable=SC1090
    source "$scripts_dir/lib/ops_process_control.sh" 2>/dev/null || true
  fi

  # Scope process kills to this project's scripts directory
  export VNX_KILL_SCOPE="$scripts_dir"

  if declare -F vnx_stop_by_fingerprints >/dev/null 2>&1; then
    # Kill each known orchestration process by its script name
    local fp
    for fp in \
      "smart_tap_v7_json_translator.sh" \
      "dispatcher_v8_minimal.sh" \
      "receipt_processor_v4.sh" \
      "vnx_supervisor_simple.sh" \
      "unified_state_manager_v2.py" \
      "generate_valid_dashboard.sh" \
      "intelligence_daemon.py" \
      "heartbeat_ack_monitor.py" \
      "dispatch_ack_watcher.sh" \
      "generate_t0_brief.sh" \
      "queue_popup_watcher.sh" \
      "receipt_notifier.sh" \
      "recommendations_engine_daemon.sh" \
      "gather_intelligence.py" \
      "cached_intelligence.py" \
      "learning_loop.py" \
      "pr_queue_manager.py" \
      "quality_intelligence_db.py" \
    ; do
      vnx_stop_by_fingerprints "$fp" "$lifecycle_log" "$reason" "$timeout" "$fp" || true
    done
  fi

  # Kill legacy orphan fswatch processes watching this project's directories.
  # fswatch is no longer started by receipt_processor (replaced by 5s polling),
  # but orphans from previous versions may still be running.
  local reports_dir="${VNX_REPORTS_DIR:-$VNX_DATA_DIR/unified_reports}"
  local pid cmd
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
    if [[ "$cmd" == *"$reports_dir"* ]] || [[ "$cmd" == *"$VNX_DATA_DIR"* ]]; then
      kill -TERM "$pid" 2>/dev/null || true
      log "Killed orphan fswatch (PID: $pid)"
    fi
  done < <(pgrep -x fswatch 2>/dev/null || true)

  unset VNX_KILL_SCOPE

  # Broad sweep: kill any remaining processes containing our scripts_dir.
  # This catches child processes and anything we may have missed above.
  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    [ "$pid" != "$$" ] || continue  # Don't kill ourselves
    kill -TERM "$pid" 2>/dev/null || true
  done < <(pgrep -f "$scripts_dir" 2>/dev/null || true)

  # Clean up stale locks and PID files so new processes can acquire them
  if [ -d "${VNX_LOCKS_DIR:-}" ]; then
    rm -rf "$VNX_LOCKS_DIR"/*.lock 2>/dev/null || true
  fi
  if [ -d "${VNX_PIDS_DIR:-}" ]; then
    rm -f "$VNX_PIDS_DIR"/*.pid "$VNX_PIDS_DIR"/*.pid.fingerprint 2>/dev/null || true
  fi

  sleep 1  # Brief pause to let processes exit cleanly
}

cmd_stop() {
  local session_name="vnx-$(basename "$PROJECT_ROOT")"

  # Stop ALL orchestration processes (comprehensive).
  vnx_kill_all_orchestration "$VNX_HOME/scripts" "$VNX_DATA_DIR/logs" "session_stop"

  # Kill tmux session.
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name"
    log "VNX session stopped."
  else
    log "No VNX session running."
  fi

  # Export intelligence to git-tracked directory after session cleanup.
  if [ -d "$VNX_INTELLIGENCE_DIR" ] || [ -f "$VNX_STATE_DIR/quality_intelligence.db" ]; then
    log "[stop] Exporting intelligence to .vnx-intelligence/..."
    cmd_intelligence_export || log "[stop] WARN: intelligence export failed (non-fatal)"
  fi
}

cmd_start() {
  local session_name="vnx-$(basename "$PROJECT_ROOT")"
  local terms_dir="$PROJECT_ROOT/.claude/terminals"
  local scripts_dir="$VNX_HOME/scripts"
  local runtime_dir="$VNX_DATA_DIR"
  local state_dir="${VNX_STATE_DIR:-$runtime_dir/state}"
  local dispatch_dir="${VNX_DISPATCH_DIR:-$runtime_dir/dispatches}"
  local log_dir="$runtime_dir/logs"

  # ── Cleanup: kill any existing VNX processes for THIS project ────────
  # Supervisor is killed first to prevent it from respawning children.
  # Pattern is scoped to PROJECT_ROOT so other projects are not affected.
  local vnx_scripts_pattern="$VNX_HOME/scripts"
  local stale_count
  stale_count=$(pgrep -f "$vnx_scripts_pattern" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$stale_count" -gt 0 ]; then
    log "Cleaning up $stale_count stale VNX process(es) for this project..."
    pkill -f "vnx_supervisor.*$(basename "$PROJECT_ROOT")" 2>/dev/null || true
    pkill -f "$vnx_scripts_pattern" 2>/dev/null || true
    pkill -f "$VNX_HOME/dashboard" 2>/dev/null || true
    sleep 1
    # Force kill anything that didn't exit cleanly
    pkill -9 -f "$vnx_scripts_pattern" 2>/dev/null || true
    pkill -9 -f "$VNX_HOME/dashboard" 2>/dev/null || true
    log "Cleanup complete."
  fi

  # ── Intelligence: export current state, then import if needed ────────
  local _intel_meta="$VNX_INTELLIGENCE_DIR/db_export/_export_meta.json"
  local _db_file="$state_dir/quality_intelligence.db"
  # Export first: capture intelligence from previous session (since vnx stop may never run)
  if [ -f "$_db_file" ]; then
    log "[start] Exporting intelligence to .vnx-intelligence/..."
    cmd_intelligence_export || log "[start] WARN: intelligence export failed (non-fatal)"
  fi
  # Then import if export is newer than DB (e.g. from git merge)
  if [ -f "$_intel_meta" ]; then
    local _need_import=false
    if [ ! -f "$_db_file" ]; then
      _need_import=true
    elif [ "$_intel_meta" -nt "$_db_file" ]; then
      _need_import=true
    fi
    if [ "$_need_import" = true ]; then
      log "[start] Intelligence export is newer than DB — importing..."
      cmd_intelligence_import || log "[start] WARN: intelligence import failed (non-fatal)"
    fi
  fi

  # ── Profile/preset support ──────────────────────────────────────────
  local profile_name=""
  local preset_name=""
  local use_last=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --profile|-p) profile_name="$2"; shift 2 ;;
      --profile=*) profile_name="${1#*=}"; shift ;;
      --preset) preset_name="$2"; shift 2 ;;
      --preset=*) preset_name="${1#*=}"; shift ;;
      --last) use_last=true; shift ;;
      *) shift ;;
    esac
  done

  local presets_dir="$runtime_dir/startup_presets"
  mkdir -p "$presets_dir"

  # Load configuration: --preset > --last > --profile > interactive menu > config.env
  if [ -n "$preset_name" ]; then
    # --preset <name>: load a saved startup preset directly
    local preset_file="$presets_dir/${preset_name}.env"
    if [ -f "$preset_file" ]; then
      # shellcheck source=/dev/null
      source "$preset_file"
      _update_last_used "$presets_dir" "$preset_file"
      log "Loaded preset: $preset_name ($preset_file)"
    else
      err "Preset not found: $preset_file"
      echo "Available presets:"
      ls "$presets_dir/"*.env 2>/dev/null | while read -r f; do
        local bname; bname="$(basename "${f%.env}")"
        [ "$bname" = "last-used" ] && continue
        echo "  $bname"
      done
      exit 1
    fi
  elif [ "$use_last" = true ]; then
    # --last: load last-used preset
    if [ -f "$presets_dir/last-used.env" ]; then
      # shellcheck source=/dev/null
      source "$presets_dir/last-used.env"
      local last_target
      last_target="$(readlink "$presets_dir/last-used.env" 2>/dev/null || echo "unknown")"
      log "Loaded last-used preset: $(basename "${last_target%.env}")"
    else
      err "No last-used preset found. Run 'vnx start' interactively first."
      exit 1
    fi
  elif [ -n "$profile_name" ]; then
    # --profile <name>: legacy profile support (backwards compatible)
    local profile_file="$runtime_dir/profiles/${profile_name}.env"
    if [ -f "$profile_file" ]; then
      # shellcheck source=/dev/null
      source "$profile_file"
      log "Loaded profile: $profile_name ($profile_file)"
    else
      err "Profile not found: $profile_file"
      echo "Available profiles:"
      ls "$runtime_dir/profiles/"*.env 2>/dev/null | while read -r f; do
        echo "  $(basename "${f%.env}")"
      done
      exit 1
    fi
  elif [ -t 0 ]; then
    # Interactive mode: show startup menu when stdin is a terminal
    if ! _interactive_startup_menu "$presets_dir"; then
      # Menu aborted or invalid choice — fall back to config.env or defaults
      if [ -f "$runtime_dir/config.env" ]; then
        source "$runtime_dir/config.env"
        log "Loaded project config: $runtime_dir/config.env"
      fi
    fi
  elif [ -f "$runtime_dir/config.env" ]; then
    # shellcheck source=/dev/null
    source "$runtime_dir/config.env"
    log "Loaded project config: $runtime_dir/config.env"
  fi
  local t1_provider="${VNX_T1_PROVIDER:-claude_code}"
  local t2_provider="${VNX_T2_PROVIDER:-claude_code}"
  local t3_provider="${VNX_T3_PROVIDER:-claude_code}"
  local gemini_model="${VNX_GEMINI_MODEL:-gemini-2.5-flash}"
  local codex_model="${VNX_CODEX_MODEL:-gpt-5.1-codex-mini}"
  local t0_flags="${VNX_T0_FLAGS:-}"

  # Skip-permissions flags (from preset/custom config)
  local t0_skip="${VNX_T0_SKIP_PERMISSIONS:-0}"
  local t1_skip="${VNX_T1_SKIP_PERMISSIONS:-0}"
  local t2_skip="${VNX_T2_SKIP_PERMISSIONS:-0}"
  local t3_skip="${VNX_T3_SKIP_PERMISSIONS:-0}"

  # Queue popup toggle (from preset/custom config)
  local queue_popup_enabled="${VNX_QUEUE_POPUP_ENABLED:-1}"
  export VNX_QUEUE_POPUP_ENABLED="$queue_popup_enabled"

  if ! command -v tmux >/dev/null 2>&1; then
    err "tmux is required for 'vnx start'. Install: brew install tmux"
    exit 1
  fi

  # Ensure runtime directories are available for both fresh starts and
  # stale-session auto-heal paths.
  mkdir -p "$state_dir" \
           "$dispatch_dir"/{pending,active,completed,rejected} \
           "$log_dir" \
           "$terms_dir"/{T0,T1,T2,T3}

  # If session already exists, attach to it. Auto-heal stale sessions that only
  # contain idle shells (no active Claude/Codex/Gemini process).
  if tmux has-session -t "$session_name" 2>/dev/null; then
    local active_cli_count=0
    active_cli_count="$(tmux list-panes -t "$session_name" -F '#{pane_current_command}' 2>/dev/null \
      | awk '$1=="node" || $1=="claude" || $1=="codex" || $1=="gemini" {c++} END {print c+0}')"

    # If a profile was explicitly selected, kill the existing session and restart
    # fresh so the chosen providers are actually applied to T1/T2.
    if [ -n "$profile_name" ] && [ "${active_cli_count:-0}" -gt 0 ]; then
      log "Profile '$profile_name' selected — restarting session to apply providers (T1=$t1_provider, T2=$t2_provider)..."
      vnx_kill_all_orchestration "$scripts_dir" "$log_dir" "profile_restart"
      tmux kill-session -t "$session_name" 2>/dev/null || true
      sleep 1
      # Fall through to fresh session creation below.

    elif [ "${active_cli_count:-0}" -eq 0 ]; then
      log "Detected stale $session_name session (shells only). Re-launching terminal CLIs..."

      # Kill ALL stale orchestration processes before re-launching CLIs.
      # Without this, re-heal creates duplicate supervisors/receipt_processors.
      vnx_kill_all_orchestration "$scripts_dir" "$log_dir" "session_reheal"

      local T0 T1 T2 T3
      T0="$(tmux list-panes -t "$session_name" -F '#{pane_id} #{pane_current_path}' 2>/dev/null | awk -v p="$terms_dir/T0" '$2==p {print $1; exit}')"
      T1="$(tmux list-panes -t "$session_name" -F '#{pane_id} #{pane_current_path}' 2>/dev/null | awk -v p="$terms_dir/T1" '$2==p {print $1; exit}')"
      T2="$(tmux list-panes -t "$session_name" -F '#{pane_id} #{pane_current_path}' 2>/dev/null | awk -v p="$terms_dir/T2" '$2==p {print $1; exit}')"
      T3="$(tmux list-panes -t "$session_name" -F '#{pane_id} #{pane_current_path}' 2>/dev/null | awk -v p="$terms_dir/T3" '$2==p {print $1; exit}')"

      # Build launch commands with skip-permissions support (re-heal path)
      local t0_reheal_cmd t1_cmd t2_cmd t3_reheal_cmd
      local t0_sf="" t1_sf="" t2_sf="" t3_sf=""
      [ "$t0_skip" = "1" ] && t0_sf=" --dangerously-skip-permissions"
      [ "$t3_skip" = "1" ] && t3_sf=" --dangerously-skip-permissions"
      t0_reheal_cmd="claude --model opus $t0_flags$t0_sf"
      t3_reheal_cmd="claude --model opus $t0_flags$t3_sf"

      case "$t1_provider" in
        codex_cli|codex)
          [ "$t1_skip" = "1" ] && t1_sf=" --full-auto"
          t1_cmd="codex -m $codex_model$t1_sf" ;;
        gemini_cli|gemini) t1_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
        *)
          [ "$t1_skip" = "1" ] && t1_sf=" --dangerously-skip-permissions"
          t1_cmd="claude --model sonnet$t1_sf" ;;
      esac
      case "$t2_provider" in
        codex_cli|codex)
          [ "$t2_skip" = "1" ] && t2_sf=" --full-auto"
          t2_cmd="codex -m $codex_model$t2_sf" ;;
        gemini_cli|gemini) t2_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
        *)
          [ "$t2_skip" = "1" ] && t2_sf=" --dangerously-skip-permissions"
          t2_cmd="claude --model sonnet$t2_sf" ;;
      esac

      local node_path="$HOME/.nvm/versions/node/v20.18.2/bin"
      local env_clean="unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR VNX_LOGS_DIR VNX_SKILLS_DIR VNX_PIDS_DIR VNX_LOCKS_DIR VNX_REPORTS_DIR VNX_DB_DIR"
      local env_set="export PROJECT_ROOT='$PROJECT_ROOT' VNX_HOME='$VNX_HOME' VNX_DATA_DIR='$VNX_DATA_DIR' VNX_SKILLS_DIR='${VNX_SKILLS_DIR:-}'"

      [ -n "$T0" ] && tmux send-keys -t "$T0" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=orchestrator && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T0' && $t0_reheal_cmd" C-m
      [ -n "$T1" ] && tmux send-keys -t "$T1" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=A && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T1' && $t1_cmd" C-m
      [ -n "$T2" ] && tmux send-keys -t "$T2" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=B && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T2' && $t2_cmd" C-m
      [ -n "$T3" ] && tmux send-keys -t "$T3" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=C && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T3' && $t3_reheal_cmd" C-m

      if [ -n "$T0" ] && [ -n "$T1" ] && [ -n "$T2" ] && [ -n "$T3" ]; then
        cat > "$state_dir/panes.json" <<PJSON
{
  "session": "$session_name",
  "t0": { "pane_id": "$T0", "role": "orchestrator", "do_not_target": true, "model": "opus", "provider": "claude_code" },
  "T0": { "pane_id": "$T0", "role": "orchestrator", "do_not_target": true, "model": "opus", "provider": "claude_code" },
  "T1": { "pane_id": "$T1", "track": "A", "model": "sonnet", "provider": "$t1_provider" },
  "T2": { "pane_id": "$T2", "track": "B", "model": "sonnet", "provider": "$t2_provider" },
  "T3": { "pane_id": "$T3", "track": "C", "model": "opus", "role": "deep", "provider": "$t3_provider" },
  "tracks": {
    "A": { "pane_id": "$T1", "track": "A", "model": "sonnet", "provider": "$t1_provider" },
    "B": { "pane_id": "$T2", "track": "B", "model": "sonnet", "provider": "$t2_provider" },
    "C": { "pane_id": "$T3", "track": "C", "model": "opus", "role": "deep", "provider": "$t3_provider" }
  }
}
PJSON
        # Reset terminal state to idle on session re-heal
        local _ts
        _ts="$(date -u +%Y-%m-%dT%H:%M:%S+00:00)"
        cat > "$state_dir/terminal_state.json" <<TSJSON
{
  "schema_version": 1,
  "terminals": {
    "T1": { "terminal_id": "T1", "status": "idle", "last_activity": "$_ts", "version": 1 },
    "T2": { "terminal_id": "T2", "status": "idle", "last_activity": "$_ts", "version": 1 },
    "T3": { "terminal_id": "T3", "status": "idle", "last_activity": "$_ts", "version": 1 }
  }
}
TSJSON
        tmux pipe-pane -o -t "$T0" "cat >> '$state_dir/t0_conversation.log'"
        tmux pipe-pane -o -t "$T1" "cat >> '$state_dir/t1_conversation.log'"
        tmux pipe-pane -o -t "$T2" "cat >> '$state_dir/t2_conversation.log'"
        tmux pipe-pane -o -t "$T3" "cat >> '$state_dir/t3_conversation.log'"
      fi

      # Re-start orchestration processes (they were killed by vnx_kill_all_orchestration above)
      if [ -f "$scripts_dir/vnx_supervisor_simple.sh" ]; then
        cd "$scripts_dir"
        VNX_QUEUE_POPUP_ENABLED="$queue_popup_enabled" nohup bash ./vnx_supervisor_simple.sh start > "$log_dir/supervisor.log" 2>&1 &
        log "Supervisor re-started (PID: $!)"
        cd "$PROJECT_ROOT"
        sleep 2
      else
        # Fallback mode only: without supervisor, start critical services directly.
        if [ -f "$scripts_dir/smart_tap_v7_json_translator.sh" ]; then
          cd "$scripts_dir"
          nohup bash ./smart_tap_v7_json_translator.sh > "$log_dir/tap.log" 2>&1 &
          log "Smart tap V7 re-started (PID: $!)"
          cd "$PROJECT_ROOT"
        fi
        if [ -f "$scripts_dir/dispatcher_v8_minimal.sh" ]; then
          cd "$scripts_dir"
          nohup bash ./dispatcher_v8_minimal.sh > "$log_dir/dispatcher.log" 2>&1 &
          log "Dispatcher V8 re-started (PID: $!)"
          cd "$PROJECT_ROOT"
        fi
        if [ -f "$scripts_dir/receipt_processor_v4.sh" ]; then
          cd "$scripts_dir"
          VNX_MODE=monitor nohup bash ./receipt_processor_v4.sh > "$log_dir/receipt_processor.log" 2>&1 &
          log "Receipt processor V4 re-started (PID: $!)"
          cd "$PROJECT_ROOT"
        fi
        if [ -f "$scripts_dir/generate_valid_dashboard.sh" ]; then
          cd "$scripts_dir"
          nohup bash ./generate_valid_dashboard.sh > "$log_dir/dashboard_gen.log" 2>&1 &
          log "Dashboard generator re-started (PID: $!)"
          cd "$PROJECT_ROOT"
        fi
        if [ -f "$scripts_dir/unified_state_manager_v2.py" ]; then
          cd "$scripts_dir"
          nohup python3 ./unified_state_manager_v2.py > "$log_dir/state_manager.log" 2>&1 &
          log "State manager re-started (PID: $!)"
          cd "$PROJECT_ROOT"
        fi
      fi
    else
      log "VNX session already running. Attaching..."
      if [ -z "${TMUX:-}" ]; then
        exec tmux attach-session -t "$session_name"
      else
        tmux switch-client -t "$session_name"
      fi
      return 0
    fi

    # Profile restart: session was killed above — fall through to fresh start below.
    # (no return here — let execution continue to the fresh session creation code)
  fi

  # ── Terminal .claude + .vnx-data symlinks ────────────────────────────
  # Symlink each terminal's .claude → project root .claude so Claude Code
  # discovers skills when CWD is a terminal subdirectory.
  # Symlink .vnx-data so report writes from terminal CWD land in the
  # project's runtime directory (not a relative path that escapes).
  for d in T0 T1 T2 T3; do
    if [ ! -L "$terms_dir/$d/.claude" ]; then
      rm -rf "$terms_dir/$d/.claude"
      ln -s "$PROJECT_ROOT/.claude" "$terms_dir/$d/.claude"
    fi
    if [ ! -L "$terms_dir/$d/.vnx-data" ]; then
      rm -rf "$terms_dir/$d/.vnx-data"
      ln -s "$runtime_dir" "$terms_dir/$d/.vnx-data"
    fi
  done

  # ── Kill ALL stale orchestration processes ──────────────────────────────
  vnx_kill_all_orchestration "$scripts_dir" "$log_dir" "session_restart"

  log "Launching VNX tmux session with 2x2 grid..."

  # ── 2x2 grid layout (single window, 4 panes) ─────────────────────────
  local T0 T1 T2 T3
  T0=$(tmux new-session -d -s "$session_name" -n main -c "$terms_dir/T0" -P -F '#{pane_id}')
  tmux set-option -t "$session_name" -g allow-rename off
  tmux set-window-option -t "$session_name:main" automatic-rename off
  tmux set-window-option -t "$session_name:main" allow-rename off
  T1=$(tmux split-window -h -t "$T0" -c "$terms_dir/T1" -P -F '#{pane_id}')
  T2=$(tmux split-window -v -t "$T0" -c "$terms_dir/T2" -P -F '#{pane_id}')
  T3=$(tmux split-window -v -t "$T1" -c "$terms_dir/T3" -P -F '#{pane_id}')

  # ── T1 provider configuration ─────────────────────────────────────────

  # Pane titles and UI.
  tmux select-pane -t "$T0" -T "T0"
  tmux select-pane -t "$T2" -T "T2"
  tmux select-pane -t "$T3" -T "T3"

  # Provider-aware pane titles
  case "$t1_provider" in
    codex_cli|codex) tmux select-pane -t "$T1" -T "T1 [CODEX]" ;;
    gemini_cli|gemini) tmux select-pane -t "$T1" -T "T1 [GEMINI]" ;;
    *) tmux select-pane -t "$T1" -T "T1" ;;
  esac
  case "$t2_provider" in
    codex_cli|codex) tmux select-pane -t "$T2" -T "T2 [CODEX]" ;;
    gemini_cli|gemini) tmux select-pane -t "$T2" -T "T2 [GEMINI]" ;;
    *) tmux select-pane -t "$T2" -T "T2" ;;
  esac
  tmux set -t "$session_name" -g pane-border-status top
  tmux set -t "$session_name" -g pane-border-format "#{pane_title}"
  tmux set -t "$session_name" -g mouse on

  # ── Panes state file (used by dispatcher/orchestration) ────────────────
  cat > "$state_dir/panes.json" <<PJSON
{
  "session": "$session_name",
  "t0": { "pane_id": "$T0", "role": "orchestrator", "do_not_target": true, "model": "opus", "provider": "claude_code" },
  "T0": { "pane_id": "$T0", "role": "orchestrator", "do_not_target": true, "model": "opus", "provider": "claude_code" },
  "T1": { "pane_id": "$T1", "track": "A", "model": "sonnet", "provider": "$t1_provider" },
  "T2": { "pane_id": "$T2", "track": "B", "model": "sonnet", "provider": "$t2_provider" },
  "T3": { "pane_id": "$T3", "track": "C", "model": "opus", "role": "deep", "provider": "$t3_provider" },
  "tracks": {
    "A": { "pane_id": "$T1", "track": "A", "model": "sonnet", "provider": "$t1_provider" },
    "B": { "pane_id": "$T2", "track": "B", "model": "sonnet", "provider": "$t2_provider" },
    "C": { "pane_id": "$T3", "track": "C", "model": "opus", "role": "deep", "provider": "$t3_provider" }
  }
}
PJSON

  # ── Initial terminal state (all idle) ──────────────────────────────────
  # Write terminal_state.json BEFORE orchestration starts so that:
  # 1. T0 sees all terminals as "idle" (ready for dispatch)
  # 2. The reconciler doesn't fall back to tmux probing (which may
  #    misdetect Claude/Codex startup activity as "working")
  # 3. Fresh installs immediately show correct state
  local _ts
  _ts="$(date -u +%Y-%m-%dT%H:%M:%S+00:00)"
  cat > "$state_dir/terminal_state.json" <<TSJSON
{
  "schema_version": 1,
  "terminals": {
    "T1": { "terminal_id": "T1", "status": "idle", "last_activity": "$_ts", "version": 1 },
    "T2": { "terminal_id": "T2", "status": "idle", "last_activity": "$_ts", "version": 1 },
    "T3": { "terminal_id": "T3", "status": "idle", "last_activity": "$_ts", "version": 1 }
  }
}
TSJSON
  log "Initial terminal state written (all idle)"

  # ── Worktree initialization (if enabled) ────────────────────────────
  # Auto-create per-terminal worktrees and register paths in terminal_state.json.
  # Skip if VNX_WORKTREES=false is set (opt-out).
  if [ "${VNX_WORKTREES:-true}" != "false" ]; then
    local worktree_script="$scripts_dir/vnx_worktree_setup.sh"
    if [ -f "$worktree_script" ]; then
      log "Initializing per-terminal worktrees..."
      bash "$worktree_script" init-terminals main 2>&1 | while read -r line; do log "WORKTREE: $line"; done

      # Register worktree paths in terminal_state.json
      for _wt_t in T1 T2 T3; do
        local _wt_dir="${PROJECT_ROOT}-wt-${_wt_t}"
        if [ -d "$_wt_dir" ]; then
          python3 "$scripts_dir/terminal_state_shadow.py" \
            set-worktree "$_wt_t" "$_wt_dir" 2>/dev/null || \
            log "WARNING: Failed to register worktree path for $_wt_t"
        fi
      done
      log "Worktree paths registered in terminal_state.json"
    fi
  fi

  # ── Conversation capture (pipe-pane) ───────────────────────────────────
  tmux pipe-pane -o -t "$T0" "cat >> '$state_dir/t0_conversation.log'"
  tmux pipe-pane -o -t "$T1" "cat >> '$state_dir/t1_conversation.log'"
  tmux pipe-pane -o -t "$T2" "cat >> '$state_dir/t2_conversation.log'"
  tmux pipe-pane -o -t "$T3" "cat >> '$state_dir/t3_conversation.log'"
  log "Conversation capture enabled for T0-T3"

  # ── Orchestration components (if available) ────────────────────────────
  if [ -f "$scripts_dir/vnx_supervisor_simple.sh" ]; then
    cd "$scripts_dir"
    VNX_QUEUE_POPUP_ENABLED="$queue_popup_enabled" nohup bash ./vnx_supervisor_simple.sh start > "$log_dir/supervisor.log" 2>&1 &
    log "Supervisor started (PID: $!)"
    cd "$PROJECT_ROOT"
    sleep 2
  else
    # Fallback mode only: without supervisor, start critical services directly.
    if [ -f "$scripts_dir/smart_tap_v7_json_translator.sh" ]; then
      cd "$scripts_dir"
      nohup bash ./smart_tap_v7_json_translator.sh > "$log_dir/tap.log" 2>&1 &
      log "Smart tap V7 started (PID: $!)"
      cd "$PROJECT_ROOT"
    fi
    if [ -f "$scripts_dir/dispatcher_v8_minimal.sh" ]; then
      cd "$scripts_dir"
      nohup bash ./dispatcher_v8_minimal.sh > "$log_dir/dispatcher.log" 2>&1 &
      log "Dispatcher V8 started (PID: $!)"
      cd "$PROJECT_ROOT"
    fi
    if [ -f "$scripts_dir/receipt_processor_v4.sh" ]; then
      cd "$scripts_dir"
      VNX_MODE=monitor nohup bash ./receipt_processor_v4.sh > "$log_dir/receipt_processor.log" 2>&1 &
      log "Receipt processor V4 started (PID: $!)"
      cd "$PROJECT_ROOT"
    fi
    if [ -f "$scripts_dir/generate_valid_dashboard.sh" ]; then
      cd "$scripts_dir"
      nohup bash ./generate_valid_dashboard.sh > "$log_dir/dashboard_gen.log" 2>&1 &
      log "Dashboard generator started (PID: $!)"
      cd "$PROJECT_ROOT"
    fi
    if [ -f "$scripts_dir/unified_state_manager_v2.py" ]; then
      cd "$scripts_dir"
      nohup python3 ./unified_state_manager_v2.py > "$log_dir/state_manager.log" 2>&1 &
      log "State manager started (PID: $!)"
      cd "$PROJECT_ROOT"
    fi
  fi

  # ── Popup queue keybindings ────────────────────────────────────────────
  local popup_script=""
  if [ -f "$scripts_dir/queue_ui_enhanced.sh" ]; then
    popup_script="$scripts_dir/queue_ui_enhanced.sh"
  fi
  if [ -n "$popup_script" ]; then
    # CRITICAL: tmux keybindings are server-wide — the last `vnx start` wins.
    # To support multiple VNX projects on the same tmux server, we store the
    # popup command as a per-session option (@vnx_popup_cmd) and bind a single
    # global key that reads the CURRENT session's option at invocation time.
    local popup_env="unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR VNX_LOGS_DIR VNX_SKILLS_DIR VNX_PIDS_DIR VNX_LOCKS_DIR VNX_REPORTS_DIR VNX_DB_DIR; export PROJECT_ROOT='$PROJECT_ROOT' VNX_HOME='$VNX_HOME' VNX_DATA_DIR='$VNX_DATA_DIR'"
    local popup_full_cmd="$popup_env; bash '$popup_script'"

    # Store per-session so Ctrl+G resolves the correct project at runtime.
    tmux set-option -t "$session_name" @vnx_popup_cmd "$popup_full_cmd" 2>/dev/null

    # Backfill: ensure all other VNX sessions also have @vnx_popup_cmd set.
    # Without this, old sessions (started before the resolver existed) have no
    # popup cmd and Ctrl+G shows "No VNX popup configured" instead of the queue.
    for _other_session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
      [ "$_other_session" = "$session_name" ] && continue
      # Skip sessions that already have a popup cmd
      _existing_cmd=$(tmux show-option -t "$_other_session" -v @vnx_popup_cmd 2>/dev/null || true)
      [ -n "$_existing_cmd" ] && continue
      # Detect project root from pane paths in that session
      _other_root=$(tmux list-panes -t "$_other_session" -F '#{pane_current_path}' 2>/dev/null \
        | head -1 | sed 's|/\.claude/terminals/.*||' || true)
      if [ -n "$_other_root" ] && [ -d "$_other_root/.claude/vnx-system" ]; then
        _other_cmd="unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR VNX_LOGS_DIR VNX_SKILLS_DIR VNX_PIDS_DIR VNX_LOCKS_DIR VNX_REPORTS_DIR VNX_DB_DIR; export PROJECT_ROOT='$_other_root' VNX_HOME='$_other_root/.claude/vnx-system' VNX_DATA_DIR='$_other_root/.vnx-data'; bash '$_other_root/.claude/vnx-system/scripts/queue_ui_enhanced.sh'"
        tmux set-option -t "$_other_session" @vnx_popup_cmd "$_other_cmd" 2>/dev/null || true
        log "Backfilled @vnx_popup_cmd on session: $_other_session (project: $_other_root)"
      fi
    done

    # Create resolver script that reads @vnx_popup_cmd from the current client session.
    # Falls back to scanning all sessions by pane path if the current session has no cmd set.
    # Keep this compatible with tmux variants that do not support `run-shell -F`.
    local resolver="/tmp/vnx_popup_resolver.sh"
    cat > "$resolver" <<'RESOLVER'
#!/usr/bin/env bash
session=""
session=$(tmux display-message -p '#{client_session}' 2>/dev/null || true)
if [ -z "$session" ]; then
    session=$(tmux list-clients -F '#{client_session}' 2>/dev/null | head -n1 || true)
fi
if [ -z "$session" ]; then
    echo "Could not determine tmux session."
    sleep 2
    exit 1
fi

# Primary: read popup cmd from current session.
cmd=$(tmux show-option -t "$session" -v @vnx_popup_cmd 2>/dev/null || true)

# Fallback: if current session has no cmd (e.g. old session before naming change),
# scan all sessions and pick the one whose PROJECT_ROOT matches the current pane path.
if [ -z "$cmd" ]; then
    current_path=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || true)
    for s in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
        candidate=$(tmux show-option -t "$s" -v @vnx_popup_cmd 2>/dev/null || true)
        if [ -z "$candidate" ]; then continue; fi
        project_root=$(echo "$candidate" | grep -oE "PROJECT_ROOT='[^']+'" | head -1 | cut -d"'" -f2 || true)
        if [ -n "$project_root" ] && [[ "$current_path" == "$project_root"* ]]; then
            cmd="$candidate"
            # Also set it on current session for future Ctrl+G calls.
            tmux set-option -t "$session" @vnx_popup_cmd "$cmd" 2>/dev/null || true
            break
        fi
    done
fi

if [ -n "$cmd" ]; then
    eval "$cmd"
else
    echo "No VNX popup configured for session: $session"
    echo "Start VNX first: vnx start"
    sleep 2
fi
RESOLVER
    chmod +x "$resolver"

    tmux bind-key -n C-g display-popup -E -w 80% -h 60% "bash $resolver" 2>/dev/null
    tmux bind-key -n 'C-\' display-popup -E -w 80% -h 60% "bash $resolver" 2>/dev/null
    tmux bind-key q display-popup -E -w 80% -h 60% "bash $resolver" 2>/dev/null
    tmux bind-key p display-popup -E -w 80% -h 60% "bash $resolver" 2>/dev/null
    log "Popup queue bound to Ctrl+G, Ctrl+\\, Ctrl+B Q/P (resolver-based)"
  fi

  # ── Clean tmux environment (prevent cross-project contamination) ──────
  # When a tmux server already has VNX sessions from another project,
  # its global environment carries stale PROJECT_ROOT, VNX_HOME, etc.
  # New panes inherit these stale vars → Claude Code resolves wrong
  # project root → skills from wrong project or no skills at all.
  #
  # Fix 1: Remove VNX vars from tmux GLOBAL environment so they don't
  #         leak into other projects' new panes.
  # Fix 2: Set session-level env vars that override tmux global env.
  for _vnx_var in PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR \
                  VNX_DISPATCH_DIR VNX_LOGS_DIR VNX_SKILLS_DIR VNX_PIDS_DIR \
                  VNX_LOCKS_DIR VNX_REPORTS_DIR VNX_DB_DIR; do
    tmux set-environment -g -u "$_vnx_var" 2>/dev/null || true
  done
  tmux set-environment -t "$session_name" PROJECT_ROOT "$PROJECT_ROOT"
  tmux set-environment -t "$session_name" VNX_HOME "$VNX_HOME"
  tmux set-environment -t "$session_name" VNX_DATA_DIR "$VNX_DATA_DIR"
  tmux set-environment -t "$session_name" VNX_STATE_DIR "$state_dir"
  tmux set-environment -t "$session_name" VNX_DISPATCH_DIR "$dispatch_dir"
  tmux set-environment -t "$session_name" VNX_SKILLS_DIR "${VNX_SKILLS_DIR:-}"

  # ── Launch CLI in each pane ───────────────────────────────────────────
  # MCP FIX: Source shell profile to ensure MCP servers inherit proper
  # environment (node, nvm, PATH). Without this, MCP servers fail in tmux.
  # SKILL FIX: Explicit cd to terminal dir so Claude Code discovers
  # .claude/skills/ via the symlink (tmux -c flag alone is insufficient).
  # ENV FIX: Unset stale VNX vars from tmux global env, then re-export
  # correct values for current project. This prevents cross-project
  # contamination (e.g. SEOcrawler paths leaking into marketing-magic-circle).
  local node_path="$HOME/.nvm/versions/node/v20.18.2/bin"
  local env_clean="unset PROJECT_ROOT VNX_HOME VNX_DATA_DIR VNX_STATE_DIR VNX_DISPATCH_DIR VNX_LOGS_DIR VNX_SKILLS_DIR VNX_PIDS_DIR VNX_LOCKS_DIR VNX_REPORTS_DIR VNX_DB_DIR"
  local env_set="export PROJECT_ROOT='$PROJECT_ROOT' VNX_HOME='$VNX_HOME' VNX_DATA_DIR='$VNX_DATA_DIR' VNX_SKILLS_DIR='${VNX_SKILLS_DIR:-}'"

  # Provider-aware launch commands for T1, T2, and T3
  # Skip-permissions: --dangerously-skip-permissions for Claude, --full-auto for Codex, --yolo already on Gemini
  local t0_cmd t1_cmd t2_cmd t3_cmd
  local t0_skip_flag="" t1_skip_flag="" t2_skip_flag="" t3_skip_flag=""

  # T0 skip-permissions (Claude only)
  [ "$t0_skip" = "1" ] && t0_skip_flag=" --dangerously-skip-permissions"
  t0_cmd="claude --model opus $t0_flags$t0_skip_flag"

  case "$t1_provider" in
    codex_cli|codex)
      [ "$t1_skip" = "1" ] && t1_skip_flag=" --full-auto"
      t1_cmd="codex -m $codex_model$t1_skip_flag" ;;
    gemini_cli|gemini)
      t1_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
    *)
      [ "$t1_skip" = "1" ] && t1_skip_flag=" --dangerously-skip-permissions"
      t1_cmd="claude --model sonnet $t0_flags$t1_skip_flag" ;;
  esac
  case "$t2_provider" in
    codex_cli|codex)
      [ "$t2_skip" = "1" ] && t2_skip_flag=" --full-auto"
      t2_cmd="codex -m $codex_model$t2_skip_flag" ;;
    gemini_cli|gemini)
      t2_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
    *)
      [ "$t2_skip" = "1" ] && t2_skip_flag=" --dangerously-skip-permissions"
      t2_cmd="claude --model sonnet $t0_flags$t2_skip_flag" ;;
  esac
  case "$t3_provider" in
    codex_cli|codex)
      [ "$t3_skip" = "1" ] && t3_skip_flag=" --full-auto"
      t3_cmd="codex -m $codex_model$t3_skip_flag" ;;
    gemini_cli|gemini)
      t3_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
    *)
      [ "$t3_skip" = "1" ] && t3_skip_flag=" --dangerously-skip-permissions"
      t3_cmd="claude --model opus $t0_flags$t3_skip_flag" ;;
  esac
  case "$t3_provider" in
    codex_cli|codex) t3_cmd="codex -m $codex_model" ;;
    gemini_cli|gemini) t3_cmd="gemini --yolo -m $gemini_model --include-directories '$PROJECT_ROOT'" ;;
    *) t3_cmd="claude --model opus $t0_flags" ;;
  esac

  tmux send-keys -t "$T0" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=orchestrator && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T0' && $t0_cmd" C-m
  tmux send-keys -t "$T1" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=A && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T1' && $t1_cmd" C-m
  tmux send-keys -t "$T2" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=B && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T2' && $t2_cmd" C-m
  tmux send-keys -t "$T3" "source ~/.zshrc 2>/dev/null && $env_clean && $env_set && export PATH=$VNX_HOME/bin:$node_path:\$PATH && export CLAUDE_ROLE=worker && export CLAUDE_TRACK=C && export CLAUDE_PROJECT_DIR='$PROJECT_ROOT' && cd '$terms_dir/T3' && $t3_cmd" C-m

  # ── Grid balancing (equal pane sizes) ────────────────────────────────
  local win_h half
  win_h=$(tmux display-message -t "$session_name" -p '#{window_height}' 2>/dev/null || echo 40)
  half=$(( win_h / 2 ))
  tmux resize-pane -t "$T0" -y "$half" 2>/dev/null || true
  tmux resize-pane -t "$T2" -y "$half" 2>/dev/null || true

  # Focus T0.
  tmux select-pane -t "$T0"

  # ── Status ─────────────────────────────────────────────────────────────
  echo ""
  echo "VNX SESSION LAUNCHED"
  echo ""
  local t1_label="Claude Sonnet" t2_label="Claude Sonnet" t3_label="Claude Opus"
  case "$t1_provider" in
    codex_cli|codex) t1_label="Codex CLI" ;;
    gemini_cli|gemini) t1_label="Gemini CLI" ;;
  esac
  case "$t2_provider" in
    codex_cli|codex) t2_label="Codex CLI" ;;
    gemini_cli|gemini) t2_label="Gemini CLI" ;;
  esac
  case "$t3_provider" in
    codex_cli|codex) t3_label="Codex CLI" ;;
    gemini_cli|gemini) t3_label="Gemini CLI" ;;
  esac
  [ -n "$profile_name" ] && echo "Profile: $profile_name"
  [ -n "$preset_name" ] && echo "Preset: $preset_name"
  echo "Layout: 2x2 grid  |  T0: Opus  |  T1: $t1_label  |  T2: $t2_label  |  T3: $t3_label"

  # Show skip-permissions status
  local skip_summary=""
  [ "$t0_skip" = "1" ] && skip_summary="${skip_summary}T0 "
  [ "$t1_skip" = "1" ] && skip_summary="${skip_summary}T1 "
  [ "$t2_skip" = "1" ] && skip_summary="${skip_summary}T2 "
  [ "$t3_skip" = "1" ] && skip_summary="${skip_summary}T3 "
  if [ -n "$skip_summary" ]; then
    echo "Skip-permissions: ${skip_summary}"
  fi
  [ "$queue_popup_enabled" = "0" ] && echo "Queue popup: disabled"

  echo ""
  echo "Controls:"
  echo "  Ctrl+G ......... Open dispatch queue popup"
  echo "  Ctrl+B Q ....... Open popup (tmux prefix style)"
  echo "  Ctrl+B D ....... Detach (keep running)"
  echo "  Mouse .......... Click to select panes"
  echo ""
  echo "Logs: $log_dir/"
  echo ""

  # Attach.
  if [ -z "${TMUX:-}" ]; then
    exec tmux attach-session -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
}

check_required_tool() {
  local tool="$1"
  if command -v "$tool" >/dev/null 2>&1; then
    log "[doctor] OK tool: $tool"
    return 0
  fi

  err "[doctor] Missing required tool: $tool"
  return 1
}

check_recommended_tool() {
  local tool="$1"
  if command -v "$tool" >/dev/null 2>&1; then
    log "[doctor] OK optional tool: $tool"
  else
    log "[doctor] WARN optional tool not found: $tool"
  fi
}

run_path_hygiene_check() {
  local check_script="$VNX_HOME/scripts/vnx_doctor.sh"
  if [ -f "$check_script" ]; then
    if bash "$check_script"; then
      return 0
    fi
    return 1
  fi

  log "[doctor] WARN: Path hygiene script missing: $check_script"
  return 0
}

run_package_check() {
  local check_script="$VNX_HOME/scripts/vnx_package_check.sh"
  if [ -f "$check_script" ]; then
    if bash "$check_script"; then
      log "[doctor] OK: Dist root contains no runtime directories."
      return 0
    fi
    return 1
  fi

  log "[doctor] WARN: Package hygiene script missing: $check_script"
  return 0
}

ensure_write_access() {
  local test_file="$VNX_STATE_DIR/.vnx_doctor_write_test"
  if touch "$test_file" 2>/dev/null; then
    rm -f "$test_file"
    log "[doctor] OK write access: $VNX_STATE_DIR"
    return 0
  fi

  err "[doctor] Cannot write to state directory: $VNX_STATE_DIR"
  return 1
}

check_required_path() {
  local path="$1"
  local kind="$2"
  if [ "$kind" = "dir" ]; then
    if [ -d "$path" ]; then
      log "[doctor] OK dir: $path"
      return 0
    fi
    err "[doctor] Missing dir: $path"
    return 1
  fi

  if [ -f "$path" ]; then
    log "[doctor] OK file: $path"
    return 0
  fi

  err "[doctor] Missing file: $path"
  return 1
}

cmd_doctor() {
  local failed=0
  local do_package_check="${VNX_DOCTOR_PACKAGE_CHECK:-0}"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --package-check|--strict)
        do_package_check=1
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "[doctor] Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  check_required_tool bash || failed=1
  check_required_tool python3 || failed=1
  check_recommended_tool rg
  check_recommended_tool jq
  check_recommended_tool tmux
  check_recommended_tool codex
  check_recommended_tool gemini

  check_required_path "$VNX_CONFIG_DIR" dir || failed=1
  check_required_path "$VNX_CONFIG_FILE" file || failed=1

  check_required_path "$VNX_DATA_DIR" dir || failed=1
  check_required_path "$VNX_STATE_DIR" dir || failed=1
  check_required_path "$VNX_LOGS_DIR" dir || failed=1
  check_required_path "$VNX_PIDS_DIR" dir || failed=1
  check_required_path "$VNX_LOCKS_DIR" dir || failed=1
  check_required_path "$VNX_DISPATCH_DIR" dir || failed=1
  check_required_path "$VNX_DISPATCH_DIR/pending" dir || failed=1
  check_required_path "$VNX_DISPATCH_DIR/active" dir || failed=1
  check_required_path "$VNX_DISPATCH_DIR/completed" dir || failed=1
  check_required_path "$VNX_REPORTS_DIR" dir || failed=1

  check_required_path "$TERMINALS_TEMPLATE_DIR/T0.md" file || failed=1
  check_required_path "$TERMINALS_TEMPLATE_DIR/T1.md" file || failed=1
  check_required_path "$TERMINALS_TEMPLATE_DIR/T2.md" file || failed=1
  check_required_path "$TERMINALS_TEMPLATE_DIR/T3.md" file || failed=1
  check_required_path "$VNX_SKILLS_DIR/skills.yaml" file || failed=1

  # Hooks checks
  check_required_path "$PROJECT_ROOT/.claude/hooks/sessionstart.sh" file || failed=1
  if [ -f "$PROJECT_ROOT/.claude/settings.json" ]; then
    if grep -q '"hooks"' "$PROJECT_ROOT/.claude/settings.json" 2>/dev/null; then
      log "[doctor] OK hooks: settings.json has hooks section"
    else
      err "[doctor] Missing hooks section in .claude/settings.json"
      failed=1
    fi
  else
    err "[doctor] Missing .claude/settings.json"
    failed=1
  fi

  # Quality intelligence database check
  local db_path="$VNX_STATE_DIR/quality_intelligence.db"
  if [ -f "$db_path" ]; then
    if command -v sqlite3 >/dev/null 2>&1; then
      local table_count
      table_count=$(sqlite3 "$db_path" "SELECT COUNT(*) FROM sqlite_master WHERE type='table'" 2>/dev/null || echo "0")
      if [ "$table_count" -ge 10 ]; then
        log "[doctor] OK quality DB: $table_count tables"
      else
        err "[doctor] Quality DB incomplete: only $table_count tables (expected ≥10). Run: vnx init-db"
        failed=1
      fi
    else
      log "[doctor] WARN: sqlite3 not available, cannot verify quality DB"
    fi
  else
    log "[doctor] WARN: Quality intelligence DB not found. Run: vnx init-db"
  fi

  # Worktree isolation checks
  if _detect_worktree_context 2>/dev/null; then
    log "[doctor] INFO: Running in git worktree: $_WT_ROOT"
    local wt_data="$_WT_ROOT/.vnx-data"
    if [ -L "$wt_data" ]; then
      err "[doctor] WARN: .vnx-data is a SYMLINK (old model). Run 'vnx worktree-start' to migrate to isolated model."
    elif [ -d "$wt_data" ] && [ -f "$wt_data/.snapshot_meta" ]; then
      local snap_date
      snap_date=$(grep '^snapshot_date=' "$wt_data/.snapshot_meta" 2>/dev/null | cut -d= -f2)
      log "[doctor] OK worktree: isolated .vnx-data (snapshot: ${snap_date:-unknown})"
      # Check snapshot freshness (warn if >14 days old)
      if command -v python3 >/dev/null 2>&1 && [ -n "$snap_date" ]; then
        local days_old
        days_old=$(python3 -c "
from datetime import datetime, timezone
try:
    snap = datetime.fromisoformat('$snap_date'.replace('Z','+00:00'))
    print((datetime.now(timezone.utc) - snap).days)
except:
    print(-1)
" 2>/dev/null)
        if [ "${days_old:-0}" -ge 14 ]; then
          log "[doctor] WARN: Intelligence snapshot is ${days_old} days old. Consider: vnx worktree-refresh"
        fi
      fi
      # Check .env_override exists
      if [ ! -f "$wt_data/.env_override" ]; then
        err "[doctor] WARN: Missing .env_override in worktree. Run 'vnx worktree-start' to fix."
      else
        log "[doctor] OK worktree: .env_override present"
      fi
    elif [ -d "$wt_data" ]; then
      err "[doctor] WARN: .vnx-data exists but no snapshot metadata. Run 'vnx worktree-start'."
    else
      err "[doctor] WARN: No .vnx-data in worktree. Run 'vnx worktree-start'."
    fi
  fi

  # Version freshness check
  if [ -f "$VNX_HOME/.vnx-origin" ]; then
    local current_version=""
    if [ -f "$VNX_HOME/version.lock" ]; then
      current_version="$(head -1 "$VNX_HOME/version.lock" | tr -d '[:space:]')"
      log "[doctor] OK version: pinned to $current_version"
    else
      log "[doctor] INFO: No version lock. Run 'vnx update --pin <tag>' to pin."
    fi
  fi

  ensure_write_access || failed=1
  run_path_hygiene_check || failed=1
  if [ "$do_package_check" -eq 1 ]; then
    run_package_check || failed=1
  fi

  if [ "$failed" -ne 0 ]; then
    err "[doctor] FAILED"
    return 1
  fi

  log "[doctor] PASSED"
}

build_block_file() {
  vnx_build_block_file "$1" "$2" "$MARKER_BEGIN" "$MARKER_END"
}

upsert_marked_block() {
  local target_file="$1"
  local snippet_file="$2"
  local result

  if ! command -v vnx_upsert_marked_block >/dev/null 2>&1; then
    err "Missing helper: vnx_upsert_marked_block"
    return 1
  fi

  # vnx_upsert_marked_block return codes:
  # 0 => unchanged, 1 => created, 2 => updated.
  if vnx_upsert_marked_block "$target_file" "$snippet_file" "$MARKER_BEGIN" "$MARKER_END"; then
    result=0
  else
    result=$?
  fi

  case "$result" in
    0)
      log "[patch-agent-files] Unchanged: $target_file"
      ;;
    1)
      log "[patch-agent-files] Created: $target_file"
      ;;
    2)
      log "[patch-agent-files] Updated: $target_file"
      ;;
    *)
      err "[patch-agent-files] Failed: $target_file"
      return 1
      ;;
  esac
}

select_snippet_for_target() {
  local target_basename="$1"
  local default_snippet="$SNIPPETS_TEMPLATE_DIR/CLAUDE_SNIPPET.md"
  local agents_snippet="$SNIPPETS_TEMPLATE_DIR/AGENTS_SNIPPET.md"

  # AGENTS.md (Codex) and GEMINI.md (Gemini) use the same provider-agnostic snippet.
  if { [ "$target_basename" = "AGENTS.md" ] || [ "$target_basename" = "GEMINI.md" ]; } && [ -f "$agents_snippet" ]; then
    printf '%s\n' "$agents_snippet"
    return 0
  fi

  if [ -f "$default_snippet" ]; then
    printf '%s\n' "$default_snippet"
    return 0
  fi

  err "Missing snippet template: $default_snippet"
  return 1
}

  cmd_patch_agent_files() {
    local target
  for target in "$PROJECT_ROOT/CLAUDE.md" "$PROJECT_ROOT/AGENTS.md" "$PROJECT_ROOT/GEMINI.md"; do
    local base
    base="$(basename "$target")"

    local snippet
    snippet="$(select_snippet_for_target "$base")"

    upsert_marked_block "$target" "$snippet"
  done

  log "[patch-agent-files] Done"
}

cmd_package_check() {
  if run_package_check; then
    return 0
  fi

  err "[package-check] FAILED - runtime artifacts detected"
  return 1
}

cmd_cost_report() {
  local tracker_script="$VNX_HOME/scripts/cost_tracker.py"
  if [ ! -f "$tracker_script" ]; then
    err "[cost-report] Missing tracker script: $tracker_script"
    return 1
  fi
  python3 "$tracker_script" "$@"
}

cmd_smoke() {
  local tmp_dir="/tmp"
  local keep=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tmp-dir)
        shift
        if [ "$#" -eq 0 ]; then
          err "[smoke] --tmp-dir requires a directory path"
          return 1
        fi
        tmp_dir="$1"
        ;;
      --keep)
        keep=1
        ;;
      -h|--help)
        cat <<SMOKE_USAGE
Usage: vnx smoke [--tmp-dir <dir>] [--keep]

Options:
  --tmp-dir <dir>  Parent temp directory (default: /tmp)
  --keep           Keep temp workspace for inspection
SMOKE_USAGE
        return 0
        ;;
      *)
        err "[smoke] Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  local workspace=""
  if [ "$tmp_dir" = "/tmp" ]; then
    workspace="$(mktemp -d "/tmp/vnx-smoke.XXXXXX")"
  else
    mkdir -p "$tmp_dir"
    workspace="$tmp_dir/vnx-smoke-$(date +%Y%m%d%H%M%S)-$$"
    mkdir -p "$workspace"
  fi

  if [ ! -d "$workspace" ]; then
    err "[smoke] Failed to create temp workspace"
    return 1
  fi

  if [ "$keep" -eq 0 ]; then
    trap "rm -rf '$workspace' 2>/dev/null || true" RETURN
  fi

  local smoke_data_dir="$workspace/.vnx-data"
  local smoke_state_dir="$smoke_data_dir/state"
  local smoke_dispatch_dir="$smoke_data_dir/dispatches"
  local smoke_logs_dir="$smoke_data_dir/logs"
  local smoke_pids_dir="$smoke_data_dir/pids"
  local smoke_locks_dir="$smoke_data_dir/locks"
  local smoke_reports_dir="$smoke_data_dir/unified_reports"
  local smoke_db_dir="$smoke_data_dir/database"
  local smoke_receipts_file="$smoke_state_dir/t0_receipts.ndjson"
  local processor_script="$VNX_HOME/scripts/receipt_processor_v4.sh"

  mkdir -p "$smoke_state_dir" \
    "$smoke_logs_dir" \
    "$smoke_pids_dir" \
    "$smoke_locks_dir" \
    "$smoke_dispatch_dir/pending" \
    "$smoke_dispatch_dir/active" \
    "$smoke_dispatch_dir/completed" \
    "$smoke_dispatch_dir/rejected" \
    "$smoke_dispatch_dir/failed" \
    "$smoke_reports_dir" \
    "$smoke_db_dir"

  touch "$smoke_receipts_file"

  local before_count
  before_count="$(wc -l < "$smoke_receipts_file" 2>/dev/null || echo 0)"

  local now_date now_ts dispatch_id report_path
  now_date="$(date -u +%Y-%m-%d)"
  now_ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  dispatch_id="smoke-dispatch-$(date -u +%Y%m%d%H%M%S)-$$"
  report_path="$smoke_reports_dir/$(date -u +%Y%m%d-%H%M%S)-${dispatch_id}-T1.md"

  cat > "$report_path" <<EOF
# IMPLEMENTATION: Smoke Receipt Test

## Metadata
- **Terminal**: T1
- **Date**: $now_date
- **Gate**: testing
- **Status**: success
- **Task ID**: smoke-task-001
- **Dispatch ID**: $dispatch_id
- **Track**: A
- **Timestamp**: $now_ts

## Summary
One-shot smoke test report to validate receipt generation.

## Tags (Required)
- [smoke-test, receipt-pipeline]

## Work Completed
- Created deterministic smoke report.
- Executed one-shot receipt processing.

## Technical Details
- Uses receipt_processor_v4 in manual mode.

## Evidence
- Receipt line should be appended to t0_receipts.ndjson.

## Open Items
None - all work completed and tested.

## Recommendations
### Immediate
- Keep smoke test in CI.
EOF

  if [ ! -f "$processor_script" ]; then
    err "[smoke] Missing processor script: $processor_script"
    return 1
  fi

  if ! VNX_DATA_DIR="$smoke_data_dir" \
    VNX_STATE_DIR="$smoke_state_dir" \
    VNX_DISPATCH_DIR="$smoke_dispatch_dir" \
    VNX_LOGS_DIR="$smoke_logs_dir" \
    VNX_PIDS_DIR="$smoke_pids_dir" \
    VNX_LOCKS_DIR="$smoke_locks_dir" \
    VNX_REPORTS_DIR="$smoke_reports_dir" \
    VNX_DB_DIR="$smoke_db_dir" \
    VNX_MODE=manual \
    bash "$processor_script"; then
    err "[smoke] Receipt processor failed"
    return 1
  fi

  local after_count
  after_count="$(wc -l < "$smoke_receipts_file" 2>/dev/null || echo 0)"
  if [ "$after_count" -le "$before_count" ]; then
    err "[smoke] FAILED: no new receipt appended to $smoke_receipts_file"
    return 1
  fi

  log "[smoke] PASSED: receipt appended ($before_count -> $after_count)"
  if [ "$keep" -eq 1 ]; then
    log "[smoke] Kept temp workspace: $workspace"
  fi
}

cmd_bootstrap_skills() {
  local project_claude_dir="$PROJECT_ROOT/.claude"
  local project_skills_dir="$project_claude_dir/skills"
  local shipped_skills_dir="$VNX_HOME/skills"

  # If skills dir exists as a real directory, keep it (canonical location).
  # If it's a stale symlink, remove it and copy fresh.
  if [ -L "$project_skills_dir" ]; then
    log "[bootstrap-skills] Removing stale symlink: $project_skills_dir"
    rm -f "$project_skills_dir"
  elif [ -d "$project_skills_dir" ]; then
    log "[bootstrap-skills] Keeping existing skills dir: $project_skills_dir"
    return 0
  fi

  if [ ! -d "$shipped_skills_dir" ]; then
    err "[bootstrap-skills] Missing shipped skills dir: $shipped_skills_dir"
    return 1
  fi

  mkdir -p "$project_claude_dir"

  # Copy skills to .claude/skills/ (canonical location).
  # Claude Code does not follow symlinks for skill discovery,
  # so we copy instead. After init, .claude/skills/ is the single
  # source of truth — edit skills there directly.
  if command -v rsync >/dev/null 2>&1; then
    rsync -a "$shipped_skills_dir/" "$project_skills_dir/"
  else
    mkdir -p "$project_skills_dir"
    cp -R "$shipped_skills_dir/." "$project_skills_dir/"
  fi
  log "[bootstrap-skills] Copied skills to: $project_skills_dir"

  if [ -f "$project_skills_dir/skills.yaml" ]; then
    log "[bootstrap-skills] OK: skills registry present"
  else
    err "[bootstrap-skills] WARN: skills.yaml not found in $project_skills_dir"
  fi

  # ── Multi-provider skill sync ─────────────────────────────────────────
  # Each CLI tool has its own skill discovery path. Sync shipped skills
  # to each provider so T1 (multi-model) always has identical capabilities.

  # Codex CLI: reads project skills from .agents/skills/ (project-scoped).
  # We no longer sync to ~/.codex/skills/ (global) to avoid polluting user's
  # global config. Project-local skills are sufficient for VNX dispatches.
  if command -v codex >/dev/null 2>&1; then
    local codex_skills_dir="$PROJECT_ROOT/.agents/skills"
    mkdir -p "$codex_skills_dir"
    if command -v rsync >/dev/null 2>&1; then
      rsync -a "$shipped_skills_dir/" "$codex_skills_dir/"
    else
      cp -R "$shipped_skills_dir/." "$codex_skills_dir/"
    fi
    log "[bootstrap-skills] Synced skills to Codex: $codex_skills_dir"
  fi

  # Gemini CLI: reads skills from <project>/.gemini/skills/ (workspace).
  # Uses same SKILL.md format, just different discovery directory.
  if command -v gemini >/dev/null 2>&1; then
    local gemini_skills_dir="$PROJECT_ROOT/.gemini/skills"
    mkdir -p "$gemini_skills_dir"
    if command -v rsync >/dev/null 2>&1; then
      rsync -a "$shipped_skills_dir/" "$gemini_skills_dir/"
    else
      cp -R "$shipped_skills_dir/." "$gemini_skills_dir/"
    fi
    log "[bootstrap-skills] Synced skills to Gemini: $gemini_skills_dir"
  fi
}

cmd_bootstrap_terminals() {
  local terminals_dir="$PROJECT_ROOT/.claude/terminals"
  local force=0
  local terminal_ids="T0 T1 T2 T3"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --force)
        force=1
        ;;
      --terminals)
        shift
        if [ "$#" -eq 0 ]; then
          err "[bootstrap-terminals] --terminals requires a value (e.g. \"T0 T1 T2 T3\")"
          return 1
        fi
        terminal_ids="$1"
        ;;
      -h|--help)
        cat <<EOF
Usage: vnx bootstrap-terminals [--terminals "T0 T1 T2 T3"] [--force]

Creates per-terminal folders under ./.claude/terminals/ and writes CLAUDE.md
from templates in: $TERMINALS_TEMPLATE_DIR

Defaults:
  --terminals "T0 T1 T2 T3"

Safety:
  Existing CLAUDE.md files are kept unless --force is set.
EOF
        return 0
        ;;
      *)
        err "[bootstrap-terminals] Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  mkdir -p "$terminals_dir"

  local terminal_id
  for terminal_id in $terminal_ids; do
    local target_dir="$terminals_dir/$terminal_id"
    local target_file="$target_dir/CLAUDE.md"
    local template_file="$TERMINALS_TEMPLATE_DIR/${terminal_id}.md"

    mkdir -p "$target_dir"

    if [ ! -f "$template_file" ]; then
      err "[bootstrap-terminals] Missing terminal template: $template_file"
      return 1
    fi

    if [ -f "$target_file" ] && [ "$force" -eq 0 ]; then
      log "[bootstrap-terminals] Keeping existing: $target_file"
      continue
    fi

    cp "$template_file" "$target_file"
    log "[bootstrap-terminals] Wrote: $target_file"
  done

  # ── Generate .mcp.json per terminal ──────────────────────────────────
  # Write an empty .mcp.json for each terminal. If the user has global MCP
  # servers in ~/.claude.json, explicitly disable them so they don't leak
  # into project terminals. This ensures predictable behaviour regardless
  # of the user's global Claude Code configuration.
  local global_claude_json="$HOME/.claude.json"
  if command -v python3 >/dev/null 2>&1 && [ -f "$global_claude_json" ]; then
    python3 - "$terminals_dir" "$terminal_ids" "$force" <<'PYEOF'
import json, os, sys

terminals_dir = sys.argv[1]
terminal_ids  = sys.argv[2].split()
force         = sys.argv[3] == "1"

# Read global MCP server definitions
with open(os.path.expanduser("~/.claude.json")) as fh:
    global_mcps = json.load(fh).get("mcpServers", {})

if not global_mcps:
    print("[bootstrap-terminals] No global MCPs detected — skipping .mcp.json generation")
    sys.exit(0)

# Build a config that disables every global MCP server
disable_all = {}
for name, cfg in global_mcps.items():
    entry = dict(cfg)
    entry["disabled"] = True
    disable_all[name] = entry

mcp_config = {"mcpServers": disable_all}

for tid in terminal_ids:
    target = os.path.join(terminals_dir, tid, ".mcp.json")
    if os.path.exists(target) and not force:
        print(f"[bootstrap-terminals] Keeping existing: {target}")
        continue
    os.makedirs(os.path.dirname(target), exist_ok=True)
    with open(target, "w") as fh:
        json.dump(mcp_config, fh, indent=2)
        fh.write("\n")
    print(f"[bootstrap-terminals] Wrote .mcp.json (all globals disabled): {target}")
PYEOF
  else
    # Fallback: write minimal empty config
    for terminal_id in $terminal_ids; do
      local mcp_file="$terminals_dir/$terminal_id/.mcp.json"
      if [ ! -f "$mcp_file" ] || [ "$force" -eq 1 ]; then
        printf '{"mcpServers": {}}\n' > "$mcp_file"
        log "[bootstrap-terminals] Wrote .mcp.json (empty): $mcp_file"
      fi
    done
  fi

  # ── Pre-trust project root for Gemini CLI ────────────────────────────
  # Gemini CLI asks "Do you trust this folder?" on first launch and then
  # crashes during the restart that applies trust (known bug in 0.29.5).
  # Pre-populate ~/.gemini/trustedFolders.json with TRUST_FOLDER for the
  # project root and terminals dir so the dialog never appears.
  local gemini_trust_file="$HOME/.gemini/trustedFolders.json"
  if command -v gemini >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1; then
    python3 - "$PROJECT_ROOT" "$gemini_trust_file" <<'PYEOF'
import json, os, sys

project_root   = sys.argv[1]
trust_file     = sys.argv[2]

new_entries = {
    project_root:                                   "TRUST_FOLDER",
    os.path.join(project_root, ".claude/terminals"): "TRUST_FOLDER",
}

# Load or create
os.makedirs(os.path.dirname(trust_file), exist_ok=True)
if os.path.exists(trust_file):
    with open(trust_file) as fh:
        trust = json.load(fh)
else:
    trust = {}

added = []
for path, level in new_entries.items():
    if path not in trust:
        trust[path] = level
        added.append(path)

with open(trust_file, "w") as fh:
    json.dump(trust, fh, indent=2)
    fh.write("\n")

if added:
    for p in added:
        print(f"[bootstrap-terminals] Gemini trust added: {p}")
else:
    print("[bootstrap-terminals] Gemini trust already set for project root")
PYEOF
  fi

  log "[bootstrap-terminals] Done"
}

cmd_bootstrap_hooks() {
  local project_claude_dir="$PROJECT_ROOT/.claude"
  local project_hooks_dir="$project_claude_dir/hooks"
  local project_settings="$project_claude_dir/settings.json"
  local shipped_hooks_dir="$VNX_HOME/hooks"
  local shipped_hook="$shipped_hooks_dir/sessionstart.sh"

  # ── Step 1: Copy hook scripts ─────────────────────────────────────
  if [ ! -f "$shipped_hook" ]; then
    err "[bootstrap-hooks] Missing shipped hook: $shipped_hook"
    return 1
  fi

  mkdir -p "$project_hooks_dir"

  # Always update hook scripts (they're generic, not user-customized)
  cp "$shipped_hook" "$project_hooks_dir/sessionstart.sh"
  chmod +x "$project_hooks_dir/sessionstart.sh"
  log "[bootstrap-hooks] Deployed: $project_hooks_dir/sessionstart.sh"

  # ── Step 2: Ensure settings.json has hooks section ────────────────
  local hook_script_path="$project_hooks_dir/sessionstart.sh"

  if [ ! -f "$project_settings" ]; then
    # No settings.json exists — create minimal one with hooks
    cat > "$project_settings" <<SETTINGS
{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(tmux *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(uname *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(mkfs *)",
      "Bash(dd *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $hook_script_path",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
SETTINGS
    log "[bootstrap-hooks] Created: $project_settings (with hooks)"

  elif command -v jq &> /dev/null; then
    # settings.json exists AND jq available — merge hooks section
    if jq -e '.hooks' "$project_settings" > /dev/null 2>&1; then
      log "[bootstrap-hooks] Keeping existing hooks in: $project_settings"
    else
      # Add hooks section to existing settings.json
      local tmp_settings="${project_settings}.tmp"
      jq --arg hook_path "bash $hook_script_path" '. + {
        "hooks": {
          "SessionStart": [
            {
              "matcher": "*",
              "hooks": [
                {
                  "type": "command",
                  "command": $hook_path,
                  "timeout": 3000
                }
              ]
            }
          ]
        }
      }' "$project_settings" > "$tmp_settings" && mv "$tmp_settings" "$project_settings"
      log "[bootstrap-hooks] Added hooks section to: $project_settings"
    fi

  else
    # settings.json exists but no jq — warn user
    if grep -q '"hooks"' "$project_settings" 2>/dev/null; then
      log "[bootstrap-hooks] Keeping existing hooks in: $project_settings"
    else
      log "[bootstrap-hooks] WARN: Cannot merge hooks into existing $project_settings (install jq)"
      log "[bootstrap-hooks] WARN: Add this to your settings.json manually:"
      log '  "hooks": { "SessionStart": [{ "matcher": "*", "hooks": [{ "type": "command", "command": "bash '"$hook_script_path"'", "timeout": 3000 }] }] }'
    fi
  fi

  log "[bootstrap-hooks] Done"
}

# ── vnx worktree-* ─────────────────────────────────────────────────────
# Worktree data isolation: snapshot + write-overlay (Option 1C + 3B)

_detect_worktree_context() {
  # Returns: 0 if in a worktree, 1 if in main repo
  # Sets: _WT_ROOT (worktree toplevel), _MAIN_ROOT (main repo root)
  local git_common_dir
  git_common_dir="$(git -C "$PROJECT_ROOT" rev-parse --git-common-dir 2>/dev/null)" || return 1
  _MAIN_ROOT="$(cd "$git_common_dir" && cd .. && pwd)"
  _WT_ROOT="$(git -C "$PROJECT_ROOT" rev-parse --show-toplevel 2>/dev/null)" || return 1

  if [ "$_MAIN_ROOT" != "$_WT_ROOT" ]; then
    return 0  # We're in a worktree
  fi
  return 1  # We're in the main repo
}

_snapshot_intelligence() {
  # Copy intelligence data from main to worktree .vnx-data/
  local main_data="$1"
  local wt_data="$2"
  local copied=0

  # Derive subdirectory names from VNX_*_DIR conventions
  local _db_sub; _db_sub="$(basename "$VNX_DB_DIR")"
  local _state_sub; _state_sub="$(basename "$VNX_STATE_DIR")"

  # Snapshot intelligence databases
  for db_name in intelligence.db quality_intelligence.db unified_state.db vnx_intelligence.db; do
    if [ -f "$main_data/$_db_sub/$db_name" ]; then
      cp "$main_data/$_db_sub/$db_name" "$wt_data/$_db_sub/$db_name"
      copied=$((copied + 1))
    fi
  done

  # Snapshot receipt history (learning loop context)
  if [ -f "$main_data/$_state_sub/t0_receipts.ndjson" ]; then
    cp "$main_data/$_state_sub/t0_receipts.ndjson" "$wt_data/$_state_sub/t0_receipts.ndjson"
    copied=$((copied + 1))
  fi

  # Snapshot startup presets
  if [ -d "$main_data/startup_presets" ]; then
    cp -R "$main_data/startup_presets/." "$wt_data/startup_presets/" 2>/dev/null || true
    copied=$((copied + 1))
  fi

  # Write snapshot metadata
  cat > "$wt_data/.snapshot_meta" <<META
snapshot_date=$(date -u +%Y-%m-%dT%H:%M:%SZ)
source_dir=$main_data
source_project=$_MAIN_ROOT
META

  log "[worktree-start] Snapshot: $copied items copied from main"
}

cmd_worktree_start() {
  # Detect if we're in a worktree
  if ! _detect_worktree_context; then
    err "[worktree-start] Not in a git worktree. Run from a worktree directory."
    err "[worktree-start] Create one with: vnx_worktree_setup.sh create <name>"
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  # Check if main has .vnx-data
  if [ ! -d "$main_data" ]; then
    err "[worktree-start] Main repo has no .vnx-data at: $main_data"
    err "[worktree-start] Run 'vnx init' in the main repo first."
    return 1
  fi

  # If .vnx-data is a symlink (old model), remove it first
  if [ -L "$wt_data" ]; then
    log "[worktree-start] Removing old symlink: $wt_data → $(readlink "$wt_data")"
    rm "$wt_data"
  fi

  # Create isolated .vnx-data directory
  if [ -d "$wt_data" ] && [ -f "$wt_data/.snapshot_meta" ]; then
    log "[worktree-start] Worktree already initialized: $wt_data"
    log "[worktree-start] Use 'vnx worktree-refresh' to update intelligence snapshot."
    return 0
  fi

  log "[worktree-start] Initializing isolated .vnx-data for worktree: $_WT_ROOT"

  # Create directory structure (reuse ensure_runtime_layout via env override)
  export VNX_DATA_DIR="$wt_data"
  export VNX_STATE_DIR="$wt_data/state"
  export VNX_DISPATCH_DIR="$wt_data/dispatches"
  export VNX_LOGS_DIR="$wt_data/logs"
  export VNX_PIDS_DIR="$wt_data/pids"
  export VNX_LOCKS_DIR="$wt_data/locks"
  export VNX_REPORTS_DIR="$wt_data/unified_reports"
  export VNX_DB_DIR="$wt_data/database"
  ensure_runtime_layout

  # Hydrate intelligence: prefer git-tracked .vnx-intelligence/ (already in worktree via git),
  # fall back to snapshot from main's .vnx-data/ for projects without .vnx-intelligence/.
  if [ -d "$_WT_ROOT/.vnx-intelligence/db_export" ]; then
    log "[worktree-start] Found .vnx-intelligence/ in worktree — importing into SQLite..."
    if ! cmd_intelligence_import; then
      log "[worktree-start] WARN: intelligence import failed, falling back to snapshot"
      _snapshot_intelligence "$main_data" "$wt_data"
    fi
  else
    _snapshot_intelligence "$main_data" "$wt_data"
  fi

  # Write .env_override (Option 3B: auto-generated)
  cat > "$wt_data/.env_override" <<OVERRIDE
# Auto-generated by vnx worktree-start ($(date -u +%Y-%m-%dT%H:%M:%SZ))
# Worktree: $_WT_ROOT
# Main repo: $_MAIN_ROOT
export VNX_DATA_DIR='$wt_data'
OVERRIDE

  # Create inbox directory on main for optional receipt relay
  mkdir -p "$main_data/inbox"

  log "[worktree-start] Isolated .vnx-data created: $wt_data"
  log "[worktree-start] .env_override written for VNX_DATA_DIR isolation"
  log "[worktree-start] Done. Run 'vnx doctor' to verify."
}

cmd_worktree_stop() {
  local merge_only=false
  local skip_merge=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --merge-only) merge_only=true; shift ;;
      --skip-merge) skip_merge=true; shift ;;
      *) err "[worktree-stop] Unknown option: $1"; return 1 ;;
    esac
  done

  if ! _detect_worktree_context; then
    err "[worktree-stop] Not in a git worktree."
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  if [ ! -d "$wt_data" ] || [ -L "$wt_data" ]; then
    err "[worktree-stop] No isolated .vnx-data found in worktree."
    return 1
  fi

  # Export intelligence: prefer git-tracked .vnx-intelligence/ export, fall back to merge script.
  if [ "$skip_merge" = false ]; then
    if [ -d "$_WT_ROOT/.vnx-intelligence" ] || [ -f "$wt_data/state/quality_intelligence.db" ]; then
      log "[worktree-stop] Exporting intelligence to .vnx-intelligence/..."
      if ! cmd_intelligence_export; then
        log "[worktree-stop] WARN: intelligence export failed, falling back to merge script"
        local merge_script="$VNX_HOME/scripts/vnx_worktree_merge_data.sh"
        if [ -f "$merge_script" ]; then
          bash "$merge_script" "$wt_data"
        fi
      fi
    else
      # Fallback: use legacy merge script for projects without .vnx-intelligence/
      local merge_script="$VNX_HOME/scripts/vnx_worktree_merge_data.sh"
      if [ -f "$merge_script" ]; then
        log "[worktree-stop] Merging intelligence data back to main..."
        bash "$merge_script" "$wt_data"
      else
        err "[worktree-stop] Merge script not found: $merge_script"
        err "[worktree-stop] Data preserved in: $wt_data"
        return 1
      fi
    fi

    # Clean up inbox relay files on main
    local wt_name
    wt_name="$(basename "$_WT_ROOT")"
    rm -f "$main_data/inbox/wt-${wt_name}.ndjson" 2>/dev/null || true
  fi

  if [ "$merge_only" = true ]; then
    log "[worktree-stop] Merge complete (--merge-only). Data preserved in: $wt_data"
    return 0
  fi

  # Clean up worktree .vnx-data
  log "[worktree-stop] Cleaning up worktree .vnx-data..."
  rm -rf "$wt_data"

  log "[worktree-stop] Done. Worktree intelligence merged to main."
}

cmd_worktree_refresh() {
  if ! _detect_worktree_context; then
    err "[worktree-refresh] Not in a git worktree."
    return 1
  fi

  local wt_data="$_WT_ROOT/.vnx-data"
  local main_data="$_MAIN_ROOT/.vnx-data"

  if [ ! -d "$wt_data" ] || [ -L "$wt_data" ]; then
    err "[worktree-refresh] No isolated .vnx-data found. Run 'vnx worktree-start' first."
    return 1
  fi

  if [ ! -d "$main_data" ]; then
    err "[worktree-refresh] Main repo .vnx-data not found: $main_data"
    return 1
  fi

  log "[worktree-refresh] Updating intelligence snapshot from main..."
  _snapshot_intelligence "$main_data" "$wt_data"
  log "[worktree-refresh] Done. Intelligence snapshot updated."
}

cmd_worktree_status() {
  log "VNX Worktree Status"
  log "==================="
  log ""

  # Show current context
  if _detect_worktree_context; then
    log "Current: WORKTREE ($_WT_ROOT)"
    log "Main:    $_MAIN_ROOT"
    local wt_data="$_WT_ROOT/.vnx-data"
    if [ -L "$wt_data" ]; then
      log "Data:    SYMLINKED (old model) → $(readlink "$wt_data")"
      log "         WARNING: Run 'vnx worktree-start' to migrate to isolated model"
    elif [ -d "$wt_data" ] && [ -f "$wt_data/.snapshot_meta" ]; then
      local snap_date
      snap_date=$(grep '^snapshot_date=' "$wt_data/.snapshot_meta" 2>/dev/null | cut -d= -f2)
      log "Data:    ISOLATED (snapshot: ${snap_date:-unknown})"
    elif [ -d "$wt_data" ]; then
      log "Data:    DIRECTORY (no snapshot metadata)"
    else
      log "Data:    NONE — run 'vnx worktree-start'"
    fi
  else
    log "Current: MAIN REPO ($PROJECT_ROOT)"
  fi

  log ""

  # List all VNX-managed worktrees
  log "Worktrees:"
  local wt_list
  wt_list="$(git -C "$PROJECT_ROOT" worktree list 2>/dev/null)" || true
  if [ -z "$wt_list" ]; then
    log "  (none)"
    return 0
  fi

  echo "$wt_list" | while IFS= read -r line; do
    local wt_path
    wt_path="$(echo "$line" | awk '{print $1}')"
    local wt_branch
    wt_branch="$(echo "$line" | sed 's/.*\[//' | sed 's/\]//')"

    # Check isolation status
    local status_icon="?"
    local wt_vnx_data="$wt_path/.vnx-data"
    if [ -L "$wt_vnx_data" ]; then
      status_icon="SYMLINK"
    elif [ -d "$wt_vnx_data" ] && [ -f "$wt_vnx_data/.snapshot_meta" ]; then
      status_icon="ISOLATED"
    elif [ -d "$wt_vnx_data" ]; then
      status_icon="DIR"
    else
      status_icon="NONE"
    fi

    log "  $wt_path [$wt_branch] data=$status_icon"
  done
}

# ── vnx update ─────────────────────────────────────────────────────────
VNX_ORIGIN_URL="https://github.com/Vinix24/vnx-orchestration-system.git"
VNX_ORIGIN_FILE="$VNX_HOME/.vnx-origin"
VNX_VERSION_LOCK="$VNX_HOME/version.lock"

cmd_update() {
  local origin_url branch="main"
  local do_pin=""
  local do_check=false
  local ignore_lock=false
  local positional=()

  # Parse flags
  while [ $# -gt 0 ]; do
    case "$1" in
      --pin)
        do_pin="$2"; shift 2
        ;;
      --pin=*)
        do_pin="${1#*=}"; shift
        ;;
      --check)
        do_check=true; shift
        ;;
      --latest)
        ignore_lock=true; shift
        ;;
      *)
        positional+=("$1"); shift
        ;;
    esac
  done

  # Handle --pin: just write the lock file and exit
  if [ -n "$do_pin" ]; then
    echo "$do_pin" > "$VNX_VERSION_LOCK"
    log "[update] Version pinned to: $do_pin"
    log "[update] Lock file: $VNX_VERSION_LOCK"
    return 0
  fi

  # Resolve origin: positional arg > .vnx-origin file > default
  if [ "${#positional[@]}" -ge 1 ]; then
    origin_url="${positional[0]}"
  elif [ -f "$VNX_ORIGIN_FILE" ]; then
    origin_url="$(head -1 "$VNX_ORIGIN_FILE" | tr -d '[:space:]')"
  else
    origin_url="$VNX_ORIGIN_URL"
  fi

  if [ "${#positional[@]}" -ge 2 ]; then
    branch="${positional[1]}"
  fi

  # Respect version lock (unless --latest)
  if [ "$ignore_lock" = false ] && [ -f "$VNX_VERSION_LOCK" ]; then
    local locked_version
    locked_version="$(head -1 "$VNX_VERSION_LOCK" | tr -d '[:space:]')"
    if [ -n "$locked_version" ]; then
      branch="$locked_version"
      log "[update] Using pinned version: $locked_version (from version.lock)"
      log "[update] Use --latest to ignore the lock."
    fi
  fi

  # Handle --check: dry-run
  if [ "$do_check" = true ]; then
    log "[update] Check mode (dry-run)"
    log "[update] Origin: $origin_url"
    log "[update] Branch/tag: $branch"
    if [ -f "$VNX_VERSION_LOCK" ]; then
      log "[update] Version lock: $(head -1 "$VNX_VERSION_LOCK" | tr -d '[:space:]')"
    else
      log "[update] Version lock: none"
    fi
    # Try to fetch remote refs to show available version
    local remote_sha
    remote_sha="$(git ls-remote "$origin_url" "$branch" 2>/dev/null | head -1 | cut -f1)" || true
    if [ -n "$remote_sha" ]; then
      log "[update] Remote SHA: ${remote_sha:0:12}"
    else
      log "[update] Remote: unable to fetch (check network/URL)"
    fi
    return 0
  fi

  log "[update] Pulling latest VNX from: $origin_url (branch: $branch)"

  local tmpdir
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  if ! git clone --depth 1 --branch "$branch" "$origin_url" "$tmpdir" 2>/dev/null; then
    err "Failed to clone $origin_url (branch: $branch)"
    return 1
  fi

  local install_script="$tmpdir/install.sh"
  if [ ! -f "$install_script" ]; then
    err "No install.sh found in repo root"
    return 1
  fi

  log "[update] Installing to: $PROJECT_ROOT"
  bash "$install_script" "$PROJECT_ROOT"

  # Persist origin for future updates
  echo "$origin_url" > "$VNX_ORIGIN_FILE"

  log "[update] Done. Run 'vnx doctor' to verify."
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)
      cmd_init
      ;;
    init-db)
      cmd_init_db
      ;;
    bootstrap-skills)
      cmd_bootstrap_skills
      ;;
    bootstrap-terminals)
      cmd_bootstrap_terminals "$@"
      ;;
    bootstrap-hooks)
      cmd_bootstrap_hooks
      ;;
    start)
      cmd_start "$@"
      ;;
    stop)
      cmd_stop
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    smoke)
      cmd_smoke "$@"
      ;;
    cost-report)
      cmd_cost_report "$@"
      ;;
    package-check)
      cmd_package_check
      ;;
    update)
      cmd_update "$@"
      ;;
    intelligence-export)
      cmd_intelligence_export
      ;;
    intelligence-import)
      cmd_intelligence_import
      ;;
    worktree-start)
      cmd_worktree_start
      ;;
    worktree-stop)
      cmd_worktree_stop "$@"
      ;;
    worktree-refresh)
      cmd_worktree_refresh
      ;;
    worktree-status)
      cmd_worktree_status
      ;;
    patch-agent-files)
      cmd_patch_agent_files
      ;;
    staging-list)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" staging-list "$@"
      ;;
    promote)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" promote "$@"
      ;;
    init-feature)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" init-feature "$@"
      ;;
    queue-status)
      python3 "$VNX_HOME/scripts/pr_queue_manager.py" queue-status "$@"
      ;;
    suggest)
      python3 "$VNX_HOME/scripts/apply_suggested_edits.py" "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
